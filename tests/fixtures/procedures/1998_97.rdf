    <j.0:event_reported_by_person rdf:resource="http://publications.europa.eu/resource/agent/Frits%20CASTRICUM"/>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-01-20</j.0:event_date>
    <j.0:event_legal_reported_by_person rdf:resource="http://publications.europa.eu/resource/agent/Frits%20CASTRICUM"/>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rapport Commission PE 1ère lecture</j.0:type>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/115881"/>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A4/1999/25</j.0:document_reference>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP"/>
    <j.0:event_legal_comment xml:lang="fr">Le rapport et les 17 amendements à la proposition de la Commission ont été adoptés sans débat. Les modifications suggérées sont plutôt de nature technique, le Parlement insistant cependant sur les mesures à prendre en vue d'harmoniser les procédures de contrôle: ressources humaines, formation des controleurs, amendes à infliger en cas de véhuicules défectueux etc.... Les amendements correspondants ne devraient cependant pas pouvoir être acceptés pour des raisons tant pratiques que politiques. Sur plusieurs amendements du rapporteur et de la commission juridique, la position sera plus ouverte.</j.0:event_legal_comment>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP"/>
  </rdf:Description>
