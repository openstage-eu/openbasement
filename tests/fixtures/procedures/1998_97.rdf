  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/115881.268243">
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-02-09</j.0:date>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:event_legal_type>
    <j.0:event_legal_uses_concept_type_decision rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-02-09</j.0:event_legal_date>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/115881"/>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-02-09</j.0:event_date>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_legal_comment xml:lang="fr">Although the Parliament was generally supportive of the proposal it adopted seventeen amendments. The main concern lies in the application of the Directive in that Member States may not evenly apply it. The proposed amendments 2, 12 and 13 would have examiner training, infringement penalties and technical and human resources harmonised as a condition of the Directive's implementation. This was rejected as being unpractical and differed too greatly from the line accepted by the Council.</j.0:event_legal_comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:type>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/115881"/>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/115881"/>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:comment xml:lang="fr">Although the Parliament was generally supportive of the proposal it adopted seventeen amendments. The main concern lies in the application of the Directive in that Member States may not evenly apply it. The proposed amendments 2, 12 and 13 would have examiner training, infringement penalties and technical and human resources harmonised as a condition of the Directive's implementation. This was rejected as being unpractical and differed too greatly from the line accepted by the Council.</j.0:comment>
    <j.2:build_info>cdm:3840  tdm:1523  xslt:3886 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:3886 builddate:25/07/2012 19:47:20</j.2:build_info>
