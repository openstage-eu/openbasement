    <j.0:reported_by rdf:resource="http://publications.europa.eu/resource/agent/Frits%20CASTRICUM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/REP_R1_byEP_CMT"/>
    <j.0:comment xml:lang="fr">Le rapport et les 17 amendements à la proposition de la Commission ont été adoptés sans débat. Les modifications suggérées sont plutôt de nature technique, le Parlement insistant cependant sur les mesures à prendre en vue d'harmoniser les procédures de contrôle: ressources humaines, formation des controleurs, amendes à infliger en cas de véhuicules défectueux etc.... Les amendements correspondants ne devraient cependant pas pouvoir être acceptés pour des raisons tant pratiques que politiques. Sur plusieurs amendements du rapporteur et de la commission juridique, la position sera plus ouverte.</j.0:comment>
    <j.2:build_info>cdm:3840  tdm:1523  xslt:3886 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:3886 builddate:25/07/2012 19:47:20</j.2:build_info>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/REP_R1_byEP_CMT"/>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PE/228051</j.0:document_reference>
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A4/1999/25</j.0:event_legal_document_reference>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP"/>
