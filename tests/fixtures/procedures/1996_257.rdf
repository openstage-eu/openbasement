    <j.0:dossier_title xml:lang="de">VORSCHALG FUER EINEN BESCHLUSS DES RATES UEBER VON DER GEMEINSCHAFT IN DEM GEMAESS DEM AM 1. FEBRUAR 1995 IN KRAFT GETRETENEN EUROPA - ABKOMMEN ZWISCHEN DEN EUROPAEISCHEN GEMEINSCHAFTEN UND IHREN MITGLIEDSTAATEN EINERSEITS UND RUMAENIEN ANDERERSEITS EINGESETZTEN ASSOZIATIONSRAT EINZUNEHMENDEN STANDPUNKT ZUR AUSFUHR BESTIMMTER STAHLERZEUGNISSE AUS RUMAENIEN IN DIE EUROPAEISCHEN GEMEINSCHAFTEN</j.0:dossier_title>
    <j.0:dossier_is_about_concept_type_dossier rdf:resource="http://publications.europa.eu/resource/authority/fd_612/1095"/>
    <j.0:procedure_code_interinstitutional_year_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1996</j.0:procedure_code_interinstitutional_year_procedure>
