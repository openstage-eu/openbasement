    <j.0:procedure_code_interinstitutional_year_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2011</j.0:procedure_code_interinstitutional_year_procedure>
    <j.0:dossier_title xml:lang="pt">Proposta de DECISÃO DO CONSELHO relativa à declaração de aceitação pelos Estados-Membros, no interesse da União Europeia, da adesão das Seicheles à Convenção de Haia de 1980 sobre os Aspectos Civis do Rapto Internacional de Crianças</j.0:dossier_title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/oj/JOC_2016_310_R_0093_01"/>
    <j.0:dossier_pending-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:dossier_pending-proposal>
