    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/201241.1223034"/>
    <j.0:title xml:lang="it">Proposta di DECISIONE DEL CONSIGLIO relativa alla dichiarazione di accettazione da parte degli Stati membri, nell'interesse dell'Unione europea, dell'adesione delle Seychelles alla convenzione dell'Aia del 1980 sugli aspetti civili della sottrazione internazionale di minori</j.0:title>
