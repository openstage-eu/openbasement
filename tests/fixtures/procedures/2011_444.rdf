  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/201241">
    <j.0:dossier_title xml:lang="el">Πρόταση ΑΠΟΦΑΣΗ ΤΟΥ ΣΥΜΒΟΥΛΙΟΥ σχετικά με τη δήλωση αποδοχής από τα κράτη μέλη, προς το συμφέρον της Ευρωπαϊκής Ένωσης, της προσχώρησης των Σεϋχελλών στη σύμβαση της Χάγης του 1980 για τα αστικά θέματα της διεθνούς απαγωγής παιδιών</j.0:dossier_title>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/celex/32015D2354"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/celex/52011PC0909"/>
