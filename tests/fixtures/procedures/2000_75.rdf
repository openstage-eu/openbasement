    <j.0:dossier_title xml:lang="pt">Proposta de DECISÃO DO CONSELHO relativa à adesão da Comunidade Europeia ao Regulamento n° 105 da Comissão Económica para a Europa das Nações Unidas relativo à homologação dos veículos destinados ao transporte de mercadorias perigosas no que diz respeito às suas características específicas de construção</j.0:dossier_title>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/celex/52000PC0172"/>
