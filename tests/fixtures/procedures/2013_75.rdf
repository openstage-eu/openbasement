    <j.0:dossier_title xml:lang="sk">Návrh ROZHODNUTIE RADY, ktorým sa určuje stanovisko, ktoré sa má prijať v mene Európskej únie na šiestom zasadnutí Konferencie zmluvných strán Štokholmského dohovoru o perzistentných organických látkach, pokiaľ ide o návrh na zmenu a doplnenie príloh A a B</j.0:dossier_title>
    <j.0:reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2013/0075/NLE</j.0:reference>
