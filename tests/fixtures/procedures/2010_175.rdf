    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/199446.405794"/>
    <j.0:dossier_title xml:lang="sk">Návrh NARIADENIE EURÓPSKEHO PARLAMENTU A RADY (EÚ) č. …/... ktorým sa mení a dopĺňa nariadenie Rady (ES) č. 2187/2005, pokiaľ ide o zákaz triedenia a obmedzenia lovu platesy bradavičnatej a kalkana veľkého vo vodách Baltského mora, Beltov a Øresundu.</j.0:dossier_title>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOC_2011_121_R_0014_01"/>
