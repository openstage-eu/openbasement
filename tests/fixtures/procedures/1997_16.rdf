  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/11702.265352">
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CS/1998/8394</j.0:event_legal_document_reference>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CS/1998/8394</j.0:document_reference>
    <j.0:comment xml:lang="fr">Le Conseil a adopté une orientation commune (CS/98/8394) et a décidé de procéder sur la base de cette orientation commune à la concertation avec le Parlement européen prévue par la déclaration commune du 4 mars 1975. Le Parlement, dans le cadre de la procédure de concertation établie par la déclaration commune du Parleemnt européen, du Conseil et de la Commission du 4 mars 1975, a fait savoir qu'il souhaite un amendement à l'orientation commune du Conseil. Le Conseil a approuvé cet amendement lors de sa 2167eme session du 15 mars 1999</j.0:comment>
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CS/1999/6670</j.0:event_legal_document_reference>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/DEC_PROCONCERT_byCONSIL"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/CONSIL"/>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/CONSIL"/>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1998-12-17</j.0:event_legal_date>
    <j.0:event_legal_comment xml:lang="fr">Le Conseil a adopté une orientation commune (CS/98/8394) et a décidé de procéder sur la base de cette orientation commune à la concertation avec le Parlement européen prévue par la déclaration commune du 4 mars 1975. Le Parlement, dans le cadre de la procédure de concertation établie par la déclaration commune du Parleemnt européen, du Conseil et de la Commission du 4 mars 1975, a fait savoir qu'il souhaite un amendement à l'orientation commune du Conseil. Le Conseil a approuvé cet amendement lors de sa 2167eme session du 15 mars 1999</j.0:event_legal_comment>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/CONSIL"/>
