    <j.0:procedure_code_interinstitutional_has_type_concept_type_procedure_code_interinstitutional rdf:resource="http://publications.europa.eu/resource/authority/procedure/NLE"/>
    <j.0:title xml:lang="sk">Návrh ROZHODNUTIE RADY o podpise v mene Únie a predbežnom vykonávaní Dohody medzi Európskou úniou na jednej strane a Spojenými štátmi americkými na strane druhej, ktorou sa stanovujú bezpečnostné postupy pre vypúšťanie satelitov Galileo z územia USA</j.0:title>
    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20250130-6997; environment: PROD; CERES: 4.24.0; IMMC2CDM: 3.2.3; workflow: PRELEG_CONSIL; rules: preleg/rules.xml#76627#2024-04-27T19:14:23; builddate: 2025-01-30T16:57:06.037; action: procedure-type;</j.2:build_info>
