    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/201457.416611"/>
    <j.0:dossier_title xml:lang="sv">Förslag till EUROPAPARLAMENTETS OCH RÅDETS FÖRORDNING om tillträdet för varor och tjänster från tredjeländer till unionens inre marknad för offentlig upphandling och förfaranden till stöd för förhandlingar om tillträde för varor och tjänster från unionen till tredjeländers marknader för offentlig upphandling</j.0:dossier_title>
