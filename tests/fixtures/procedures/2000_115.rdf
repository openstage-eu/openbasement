    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:event_legal_type>
    <j.0:event_legal_comment xml:lang="en">La Commission peut accepter les amendements 1, 4, 13, 17, 50, 85, 88, 97, 112, 125 et 141,dans leur esprit (entièrement ou partiellement) les amendements 2, 7, 10, 21, 23, 30, 31, 35, 38, 40, 45, 46, 47, 51, 54, 65, 70, 74, 77, 80, 86, 87, 89, 100, 104, 109, 110, 121, 123, 126, 127, 132, 137, 138, 145, 147, 150, 153, 170, 171, 172 et 175, sous réserve de reformulation (entièrement ou partiellement) les amendements 5, 9, 11, 15, 24, 34, 36, 93, 95, 113, 114, 142 et 168 par contre elle ne peut pas accepter les amendements 8, 25, 29, 32, 37, 49, 57, 63, 66, 68, 69, 71, 72, 73, 75, 76, 78, 81, 82, 83, 84, 90, 92, 94, 99, 102, 103, 107, 108, 111, 115, 116, 117, 131, 139, 151, 159, 161, 162, 173 et 176.</j.0:event_legal_comment>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/157679"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-01-17</j.0:event_legal_date>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:type>
    <j.0:comment xml:lang="en">La Commission peut accepter les amendements 1, 4, 13, 17, 50, 85, 88, 97, 112, 125 et 141,dans leur esprit (entièrement ou partiellement) les amendements 2, 7, 10, 21, 23, 30, 31, 35, 38, 40, 45, 46, 47, 51, 54, 65, 70, 74, 77, 80, 86, 87, 89, 100, 104, 109, 110, 121, 123, 126, 127, 132, 137, 138, 145, 147, 150, 153, 170, 171, 172 et 175, sous réserve de reformulation (entièrement ou partiellement) les amendements 5, 9, 11, 15, 24, 34, 36, 93, 95, 113, 114, 142 et 168 par contre elle ne peut pas accepter les amendements 8, 25, 29, 32, 37, 49, 57, 63, 66, 68, 69, 71, 72, 73, 75, 76, 78, 81, 82, 83, 84, 90, 92, 94, 99, 102, 103, 107, 108, 111, 115, 116, 117, 131, 139, 151, 159, 161, 162, 173 et 176.</j.0:comment>
