    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20250717-4401; environment: PROD; CERES: 4.29.0; IMMC2CDM: 3.2.3; workflow: PRELEG_COM; rules: /Ruleset#version:#preleg-20250326-0Trules.xml; builddate: 2025-07-17T12:47:46.567;</j.2:build_info>
