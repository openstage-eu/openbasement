  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/200064.420743">
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2012-12-11</j.0:event_date>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R2_byCOM"/>
    <j.2:build_info>cdm:CDM_2.1.7  tdm:1523  xslt:3945 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:1.2.0 builddate:15/10/2014 20:46:10</j.2:build_info>
    <j.0:event_legal_comment xml:lang="en">In line with the Commission's position on the amendments of the Parliament in the first reading on the proposal for a MFA for the Kyrgyz Republic (in the same Plenary) and given the conflict between the Parliament and the Council on this sensitive procedural issue, which blocks currently all MFA proposals and which requires a compromise solution between the two institutions, the Commission proposes to keep a specific justification for the application of the Advisory Procedure for the adoption of a MoU</j.0:event_legal_comment>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R2_byCOM"/>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/200064"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en deuxième lecture</j.0:event_legal_type>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2012-12-11</j.0:date>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/200064"/>
    <j.0:comment xml:lang="en">In line with the Commission's position on the amendments of the Parliament in the first reading on the proposal for a MFA for the Kyrgyz Republic (in the same Plenary) and given the conflict between the Parliament and the Council on this sensitive procedural issue, which blocks currently all MFA proposals and which requires a compromise solution between the two institutions, the Commission proposes to keep a specific justification for the application of the Advisory Procedure for the adoption of a MoU</j.0:comment>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R2_byCOM"/>
