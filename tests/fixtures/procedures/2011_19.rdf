    <j.0:dossier_title xml:lang="ro">Propunere de DECIZIE A CONSILIULUI de autorizare a introducerii pe piață a produselor care conțin, sunt compuse sau fabricate din bumbac modificat genetic GHB614 (BCS-GHØØ2-5) în temeiul Regulamentului (CE) nr. 1829/2003 al Parlamentului European și al Consiliului</j.0:dossier_title>
    <j.0:is_about rdf:resource="http://publications.europa.eu/resource/authority/fd_612/1095"/>
