    <j.2:build_info>cdm:3840  tdm:1523  xslt:3886 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:3886 builddate:19/07/2012 20:39:03</j.2:build_info>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP"/>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rapport Commission PE 1ère lecture</j.0:event_legal_type>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-02-17</j.0:event_date>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/138119"/>
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PE/229105</j.0:event_legal_document_reference>
    <j.0:event_legal_comment xml:lang="fr">The SWOBODA report was adopted by a large majority following the approval of several amendments. The rapporteur criticised the complicated and excessive amount of detail in the Commission proposal and called for more national scope for manoeuvre and greater flexibility. The report stresses that competition should be ensured by opening up markets for cross-border freight traffic and calls for the proposal for Authorised Applicants to be left to national legislation. The Commission was unable to accept many of the amendments considering some of them too restrictive in their scope while others on external costs were not sufficiently flexible and the optimal use of railway infrastructure was not ensured</j.0:event_legal_comment>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP"/>
    <j.0:gets_report_of rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP_TRAN"/>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A4/1999/59</j.0:document_reference>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/REP_R1_byEP_CMT"/>
    <j.0:comment xml:lang="fr">The SWOBODA report was adopted by a large majority following the approval of several amendments. The rapporteur criticised the complicated and excessive amount of detail in the Commission proposal and called for more national scope for manoeuvre and greater flexibility. The report stresses that competition should be ensured by opening up markets for cross-border freight traffic and calls for the proposal for Authorised Applicants to be left to national legislation. The Commission was unable to accept many of the amendments considering some of them too restrictive in their scope while others on external costs were not sufficiently flexible and the optimal use of railway infrastructure was not ensured</j.0:comment>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rapport Commission PE 1ère lecture</j.0:type>
    <j.0:event_legal_gets_report_of_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP_TRAN"/>
  </rdf:Description>
