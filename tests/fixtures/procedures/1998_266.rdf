    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP"/>
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A4/1999/59</j.0:event_legal_document_reference>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:event_reported_by_person rdf:resource="http://publications.europa.eu/resource/agent/Johannes%20Hannes%20SWOBODA"/>
