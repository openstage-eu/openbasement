    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:event_legal_comment xml:lang="en">The Commission agrees with the following amendments: 4, 7, 8, 10, 12, 20, 25, 26, 34 and 40.&amp;#13;
The Commission agrees with the following amendments as part of the compromise package:&amp;#13;
3(1), 6, 9, 11, 15, 16, 17, 18, 23, 32(2), 37 and 39. The Commission does not agree with the following amendments: 1, 2, 3(2), 5, 13, 14, 19, 21, 22, 24, 27, 28, 29, 30, 31, 32(1), 33, 35, 36, and 41.&amp;#13;
&amp;#13;
</j.0:event_legal_comment>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_legal_uses_concept_type_decision rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-11-19</j.0:event_date>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-11-19</j.0:date>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/179010"/>
    <j.0:comment xml:lang="en">The Commission agrees with the following amendments: 4, 7, 8, 10, 12, 20, 25, 26, 34 and 40.&amp;#13;
The Commission agrees with the following amendments as part of the compromise package:&amp;#13;
3(1), 6, 9, 11, 15, 16, 17, 18, 23, 32(2), 37 and 39. The Commission does not agree with the following amendments: 1, 2, 3(2), 5, 13, 14, 19, 21, 22, 24, 27, 28, 29, 30, 31, 32(1), 33, 35, 36, and 41.&amp;#13;
&amp;#13;
</j.0:comment>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_RSI_byCOM"/>
