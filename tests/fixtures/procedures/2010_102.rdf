  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/199250">
    <j.0:title xml:lang="mt">Proposta għal DEĊIŻJONI TAL-KUNSILL dwar il-konklużjoni ta’ Protokoll għall-Ftehim ta’ Sħubija u Kooperazzjoni bejn il-Komunitajiet Ewropej u l-Istati Membri tagħhom, min-naħa l-waħda, u r-Repubblika tal-Moldova, min-naħa l-oħra, dwar Ftehim Qafas bejn l-Unjoni Ewropea u r-Repubblika tal-Moldova dwar il-prinċipji ġenerali għall-parteċipazzjoni tar-Repubblika tal-Moldova fil-programmi tal-Unjoni</j.0:title>
    <j.0:reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2010/0102/NLE</j.0:reference>
    <j.0:number_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0102</j.0:number_procedure>
