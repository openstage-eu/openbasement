    <j.0:dossier_date_adopted rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-03</j.0:dossier_date_adopted>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/procedure-event/2023_420.2023-11-27_ADP_byCOM"/>
    <j.0:dossier_title xml:lang="mt">Proposta għal DEĊIŻJONI TAL-KUNSILL dwar il-pożizzjoni li għandha tiġi adottata mill-Unjoni fil-Kumitat Konġunt GNSS UE/ASECNA stabbilit bil-Ftehim ta’ Kooperazzjoni bejn l-Unjoni Ewropea, minn naħa waħda, u l-Aġenzija għas-Sigurtà tan-Navigazzjoni bl-Ajru fl-Afrika u f’Madagascar (ASECNA), min-naħa l-oħra, dwar l-iżvilupp tar-radjunavigazzjoni bis-satellita u l-provvista ta’ servizzi relatati fiż-żona ta’ kompetenza tal-ASECNA għall-benefiċċju tal-avjazzjoni ċivili</j.0:dossier_title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/immc/ST%206448%202024%20ADD%201%20REV%201"/>
