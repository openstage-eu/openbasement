  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/175213.341014">
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-10-22</j.0:event_legal_date>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/175213"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/175213"/>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/175213"/>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:event_legal_type>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-10-22</j.0:event_date>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:event_legal_uses_concept_type_decision rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:type>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:event_legal_comment xml:lang="en">Les propositions de modification des actes constitutifs des organismes communautaires ont été élaborées suite à l'adoption du nouveau règlement financier général. Elles touchent seize organismes communautaires. Le rapport du Parlement dont il est question ici ne concerne que les quatre d'entre eux qui font l'objet d'une procédure de co-décision. Sur les 42 amendements adoptés en première lecture, la Commission peut en accepter 11 tels qu'ils sont formulés. Elle peut accepter, éventuellement avec des modifications de formulation, le contenu de 20 amendements qu'elle inclut non dans les actes constitutifs des organismes communautaires, mais dans le règlement financier cadre, et elle rejette 11 amendements.</j.0:event_legal_comment>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-10-22</j.0:date>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:comment xml:lang="en">Les propositions de modification des actes constitutifs des organismes communautaires ont été élaborées suite à l'adoption du nouveau règlement financier général. Elles touchent seize organismes communautaires. Le rapport du Parlement dont il est question ici ne concerne que les quatre d'entre eux qui font l'objet d'une procédure de co-décision. Sur les 42 amendements adoptés en première lecture, la Commission peut en accepter 11 tels qu'ils sont formulés. Elle peut accepter, éventuellement avec des modifications de formulation, le contenu de 20 amendements qu'elle inclut non dans les actes constitutifs des organismes communautaires, mais dans le règlement financier cadre, et elle rejette 11 amendements.</j.0:comment>
    <j.2:build_info>cdm:CDM_2.1.7  tdm:1523  xslt:3945 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:1.1.9 builddate:13/02/2014 11:44:22</j.2:build_info>
  </rdf:Description>
