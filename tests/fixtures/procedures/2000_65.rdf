  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/155558.310595">
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/155558"/>
    <j.0:event_legal_comment xml:lang="en">Subject to certain editorial re-drafting, the Commission accepts amendments 2, 4, 5, 6, 7, 8, 22 and 24. Amendment 1 and 3 are only partially accepted in the part suggesting the removal of the age element from the criteria to impose a refusal of access order. The banning provision based on the flag of the vessel or the absence of a Voyage data recorder are rejected. Amendment 24 proposing a recital on very high risk flags is not accepted since it is not reflected in the Directive.</j.0:event_legal_comment>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-11-30</j.0:event_date>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-11-30</j.0:event_legal_date>
