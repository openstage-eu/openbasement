    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2004-02-11</j.0:event_legal_date>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:event_legal_type>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:comment xml:lang="en">La Commission peut accepter, le cas échéant moyennant des ajustements, les amendements qui visent à clarifier la proposition tout en sauvegardant les garanties existantes pour les migrants ainsi que les objectifs de simplification et de facilitation de la prestation de services. La Commission accepte dans leur entièreté les amendements 29, 34, 52, 70, 94, 143, 146, 152 et 192. Par ailleurs, elle accepte partiellement, dans l'esprit ou moyennant adaptation les amendements 5, 8, 9, 12, 26, 31, 32, 39, 53, 55, 58, 62, 63, 68, 80, 81, 86, 87, 88, 89, 90, 93, 95, 96, 97, 101, 102, 110, 114, 116, 136, 139, 141, 151, 154, 159, 160, 161, 162, 181, 185, 189, 193, 207, 216 et 217.</j.0:comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
