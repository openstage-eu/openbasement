  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/117436.275012">
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-05-06</j.0:event_date>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en lecture unique</j.0:event_legal_type>
    <j.0:event_legal_comment xml:lang="fr">From the amendments, which had been adopted by Parliament in November 1998, the amendment calling for flexibility concerning the deadline for the presentation of programmes by the candidate countries has been partially taken up in the final text of the Council. Other amendments were considered superfluous either because they had been taken into account, in total or partially, in the Council's text or they had to be dealt with in the new co-ordination regulation. Another group of non-accepted amendments referred to the fundamental substance of the proposal which the Commission was not willing to change.</j.0:event_legal_comment>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1030"/>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_RSI_byCOM"/>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/117436"/>
    <j.0:comment xml:lang="fr">From the amendments, which had been adopted by Parliament in November 1998, the amendment calling for flexibility concerning the deadline for the presentation of programmes by the candidate countries has been partially taken up in the final text of the Council. Other amendments were considered superfluous either because they had been taken into account, in total or partially, in the Council's text or they had to be dealt with in the new co-ordination regulation. Another group of non-accepted amendments referred to the fundamental substance of the proposal which the Commission was not willing to change.</j.0:comment>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-05-06</j.0:event_legal_date>
