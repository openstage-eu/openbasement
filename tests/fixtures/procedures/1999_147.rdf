    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/11997E133"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:title xml:lang="pt">Proposta de DECISÃO DO CONSELHO E DA COMISSÃO relativa à posição a adoptar pela Comunidade no âmbito do Conselho de Associação instituído pelo Acordo Europeu entre as Comunidades Europeias e os seus Estados-membros, por um lado, e a República da Lituânia, por outro, assinado em 12 de Junho de 1995, no que respeita à adopção das normas em matéria de auxílios estatais necessárias à aplicação do n° 1, alínea iii), e do n° 2 do artigo 64° do Acordo Europeu</j.0:title>
    <j.0:based_on rdf:resource="http://publications.europa.eu/resource/celex/11997E300"/>
    <j.0:dossier_title xml:lang="fi">Ehdotus: NEUVOSTON JA KOMISSION PÄÄTÖS Euroopan yhteisöjen ja niiden jäsenvaltioiden sekä Liettuan tasavallan 12 päivänä kesäkuuta 1995 allekirjoitetulla Eurooppa-sopimuksella perustetussa assosiaationeuvostossa vahvistettavasta yhteisön kannasta Eurooppa-sopimuksen 64 artiklan 1 kohdan iii alakohdan ja 2 kohdan täytäntöönpanemiseksi tarvittavien valtiontukia koskevien sääntöjen vahvistamisesta</j.0:dossier_title>
    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/11951K095"/>
    <j.0:dossier_title xml:lang="sv">Förslag till RÅDETS OCH KOMMISSIONENS BESLUT om vilken ståndpunkt gemenskapen skall inta i det associeringsråd som inrättas genom Europaavtalet mellan Europeiska gemenskaperna och deras medlemsstater, å ena sidan, och Litauen, å andra sidan, undertecknat den 12 juni 1995, när det gäller antagandet av regler för genomförande av de bestämmelser om statligt stöd som avses i artikel 64.1 iii och 64.2 i Europaavtalet</j.0:dossier_title>
    <j.0:number_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0147</j.0:number_procedure>
    <j.0:date_adopted rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-02-22</j.0:date_adopted>
