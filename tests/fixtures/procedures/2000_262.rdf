  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/159161.322151">
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-07-05</j.0:date>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/159161"/>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/159161"/>
    <j.0:event_legal_comment xml:lang="en">Commissioner LIIKANEN informed the House that the Commission could not accept, inter alia, those amendments relating to comitology. It could however accept those amendments which aimed to simplify the noise testing procedures, reduce the conformity assessment costs for SMEs and clarify the requirements in the case of replacement engines. It could also accept, in principle, those amendments concerning the distinction of stern drive engines, the formulas to be used for the noise testing procedures and clarification of the coverage of replacement engines.</j.0:event_legal_comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-07-05</j.0:event_date>
