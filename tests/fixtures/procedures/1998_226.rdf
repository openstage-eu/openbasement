    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP"/>
    <j.0:gets_report_of rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP_TRAN"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-01-20</j.0:date>
    <j.0:comment xml:lang="fr">Le rapporteur au nom de la commission des transports a déposé neuf amendements visant notamment à minimiser dans le transport combiné le trajet effectué par route et à maintenir l'interdiction de circuler mentionnée supra. La Commission, par l'intermédiaire de M. BRITTAN, n'a pu accepter que de deux amendements de détail et s'est bien sûr opposée au maintien de l'interdiction en cause. La plénière a suivi la position du rapporteur, adopté ses amendements et refusé un amendement déposé par M. WIJZENBEECK qui était faborable à la Commission. </j.0:comment>
    <j.0:event_legal_reported_by_person rdf:resource="http://publications.europa.eu/resource/agent/Rijk%20VAN%20DAM"/>
    <j.0:event_reported_by_person rdf:resource="http://publications.europa.eu/resource/agent/Rijk%20VAN%20DAM"/>
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PE/228431</j.0:event_legal_document_reference>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/REP_R1_byEP_CMT"/>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/134199"/>
    <j.0:event_legal_gets_report_of_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP_TRAN"/>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-01-20</j.0:event_legal_date>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rapport Commission PE 1ère lecture</j.0:type>
    <j.0:event_legal_comment xml:lang="fr">Le rapporteur au nom de la commission des transports a déposé neuf amendements visant notamment à minimiser dans le transport combiné le trajet effectué par route et à maintenir l'interdiction de circuler mentionnée supra. La Commission, par l'intermédiaire de M. BRITTAN, n'a pu accepter que de deux amendements de détail et s'est bien sûr opposée au maintien de l'interdiction en cause. La plénière a suivi la position du rapporteur, adopté ses amendements et refusé un amendement déposé par M. WIJZENBEECK qui était faborable à la Commission. </j.0:event_legal_comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
