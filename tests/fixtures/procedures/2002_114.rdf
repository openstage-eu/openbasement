    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/OPI_byCOR"/>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/OPI_byCOR"/>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-02-12</j.0:event_legal_date>
    <j.0:event_legal_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOC_2003_128_R_0006_01"/>
    <j.0:comment xml:lang="en">Le Comité des Régions soutient largement les propositions de réforme de la politique commune de la pêche (PCP) et insiste sur la priorité de la durabilité en tant que clef de l'avenir du secteur. Il s'inquiète pour deux problèmes essentiels : la nécessité d'avoir un bon équilibre entre le secteur de la pêche et la dimension environnementale et la compensation adéquate par le biais de mesures sociales et économiques des gens qui vont arrêter leur activité dans ce secteur. </j.0:comment>
    <j.0:event_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOC_2003_128_R_0006_01"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/oj/JOC_2003_128_R_0006_01"/>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avis Comité des Régions</j.0:event_legal_type>
