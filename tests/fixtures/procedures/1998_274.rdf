    <j.0:contains rdf:resource="http://publications.europa.eu/resource/comnat/COM_1998_0515_FIN"/>
    <j.0:dossier_title xml:lang="pt">Proposta de DECISÃO DO CONSELHO relativa a uma medida específica para promover a reconversão de certas actividades de pesca e que altera a Decisão do Conselho n° 97/292/CE</j.0:dossier_title>
