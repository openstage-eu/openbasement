    <j.0:dossier_title xml:lang="es">Propuesta de DECISIÓN DEL CONSEJO sobre una medida específica para fomentar la reconversión de determinadas actividades de pesca y por la que se modifica la Decisión nº 97/292/CE del Consejo de 28 de abril de 1997</j.0:dossier_title>
    <j.0:produces rdf:resource="http://publications.europa.eu/resource/celex/31999D0027"/>
    <j.0:procedure_code_interinstitutional_reference_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1998/0274/CNS</j.0:procedure_code_interinstitutional_reference_procedure>
    <j.0:dossier_adopted-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</j.0:dossier_adopted-proposal>
    <j.0:title xml:lang="da">Forslag RÅDETS BESLUTNING om en specifik foranstaltning til fremme af omstillingen af visse fiskeriaktiviteter og om ændring af Rådets beslutning nr. 97/292/EF af 28. april 1997 (98/../EF)</j.0:title>
    <j.0:title xml:lang="nl">Voorstel voor een  BESCHIKKING VAN DE RAAD inzake een specifieke maatregel ter bevordering van de omschakeling van bepaalde visserijactiviteiten en tot wijziging van Beschikking 97/292/EG van de Raad van 28 april 1997</j.0:title>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
