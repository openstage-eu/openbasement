    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20191112-3954; environment: PROD; newCERES: 3.26.6; IMMC2CDM: 2.9.1; rules: preleg/rules-consil.xml#51427#2019-10-03; builddate: 2019-11-12T19:03:58.868;</j.2:build_info>
