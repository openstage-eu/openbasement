    <j.0:dossier_title xml:lang="hu">Javaslat: AZ EURÓPAI PARLAMENT ÉS A TANÁCS IRÁNYELVE a 77/91/EGK, a 78/855/EGK, a 82/891/EGK és a 2005/56/EK tanácsi irányelvnek az egyesülések és szétválások esetében alkalmazandó jelentési és dokumentációs kötelezettségek tekintetében történő módosításáról</j.0:dossier_title>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/197421.401576"/>
