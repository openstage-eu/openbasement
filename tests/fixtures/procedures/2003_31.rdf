    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:date_adopted rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-03-27</j.0:date_adopted>
    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12002E300"/>
