    <j.0:dossier_title xml:lang="fi">Ehdotus NEUVOSTON TÄYTÄNTÖÖNPANOPÄÄTÖS tiiviimmän yhteistyön toteuttamisesta Euroopan syyttäjänviraston (EPPO) perustamisessa annetun asetuksen (EU) 2017/1939 14 artiklan 3 kohdassa tarkoitetuista valintalautakunnan toimintaa koskevista säännöistä 13 päivänä heinäkuuta 2018 annetun neuvoston täytäntöönpanopäätöksen (EU) 2018/1696 muuttamisesta</j.0:dossier_title>
    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20250325-2921; environment: PROD; CERES: 4.27.0; IMMC2CDM: 3.2.3; workflow: PRELEG_CONSIL; rules: /Ruleset#version:#preleg-20250124-0Trules.xml; builddate: 2025-03-25T13:49:57.442; action: procedure-type;</j.2:build_info>
