    <j.0:identifier>procedure:2019_75</j.0:identifier>
    <j.0:title xml:lang="sl">Predlog SKLEP SVETA o podpisu, v imenu Evropske unije, in začasni uporabi Sporazuma o partnerstvu o trajnostnem ribištvu med Evropsko unijo in Republiko Gambijo ter njegovega protokola o izvajanju</j.0:title>
    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12016E218"/>
    <j.0:dossier_title xml:lang="lt">Pasiūlymas TARYBOS SPRENDIMAS dėl Europos Sąjungos ir Gambijos Respublikos tausios žvejybos partnerystės susitarimo ir jo įgyvendinimo protokolo pasirašymo Europos Sąjungos vardu ir laikino taikymo</j.0:dossier_title>
    <j.2:build_info>reception-ID: PO-20190618-3973; environment: PROD; newCERES: 3.26.4; IMMC2CDM: 2.8.0; rules: preleg/rules-consil.xml#39852#2018-05-06; builddate: 2019-06-18T17:24:16.31;</j.2:build_info>
