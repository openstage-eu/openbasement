    <j.0:dossier_title xml:lang="da">Forslag til EUROPA-PARLAMENTETS OG RÅDETS FORORDNING om fastsættelse af forvaltnings-, bevarelses- og kontrolforanstaltninger, der skal anvendes i området for Tunkommissionen for Det Indiske Ocean (IOTC), og om ændring af Rådets forordning (EF) nr. 1936/2001, (EF) nr. 1984/2003 og (EF) nr. 520/2007</j.0:dossier_title>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#procedure_code_interinstitutional"/>
    <j.0:dossier_title xml:lang="mt">Proposta għal REGOLAMENT TAL-PARLAMENT EWROPEW U TAL-KUNSILL li jistabbilixxi l-miżuri ta’ ġestjoni, ta’ konservazzjoni u ta’ kontroll li japplikaw fiż-Żona ta’ Kompetenza tal-Kummissjoni dwar it-Tonn tal-Oċean Indjan (IOTC) u li jemenda r-Regolamenti tal-Kunsill (KE) Nru 1936/2001, (KE) Nru 1984/2003 u (KE) Nru 520/2007</j.0:dossier_title>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/immc/ST%208188%202022%20INIT"/>
    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20221013-4678; environment: PROD; CERES: 4.17.2; IMMC2CDM: 3.2.2; rules: preleg/rules-ep.xml#56614#2020-05-29T09:45:21; builddate: 2022-10-13T12:03:36.854;</j.2:build_info>
