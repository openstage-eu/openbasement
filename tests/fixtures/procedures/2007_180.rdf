    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/celex/32008D0199"/>
    <j.0:title xml:lang="ro">Propunere de DECIZIE A CONSILIULUI privind semnarea şi aplicarea cu titlu provizoriu a unui protocol la Acordul euromediteranean între Comunităţile Europene şi statele membre ale acestora, pe de o parte, şi Republica Arabă Egipt, pe de altă parte, pentru a ţine seama de aderarea Republicii Bulgaria şi a României la Uniunea Europeană</j.0:title>
    <j.0:dossier_initiated_by_act_preparatory rdf:resource="http://publications.europa.eu/resource/celex/52007PC0487%2802%29"/>
