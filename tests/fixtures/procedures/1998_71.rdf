    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/OPI_R1_byEP"/>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/celex/51998AP0495"/>
