    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-01-19</j.0:event_legal_date>
    <j.0:event_legal_comment xml:lang="fr">Le rapporteur a accueilli favorablement cette proposition tout en souhaitant en renforcer le mécanisme et a déposé 9 amendements à cette fin. Pour la Commission, M. BANGEMANN n'a pu en reprendre que trois, plutôt modestes dans leur portée, et s'est opposé en particulier à la prolongation du délai de prescription des créances telle que proposée par la commission compétente, à la prééminence des créances dues au budget communautaire qui pose de sérieux problèmes juridiques et au maintien définitif du principe de remboursement de frais entre Etats membres. Tous les amendements proposés par le rapporteur ont été adoptés par la plénière à une large majorité.</j.0:event_legal_comment>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-01-19</j.0:date>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rapport Commission PE 1ère lecture</j.0:event_legal_type>
    <j.0:comment xml:lang="fr">Le rapporteur a accueilli favorablement cette proposition tout en souhaitant en renforcer le mécanisme et a déposé 9 amendements à cette fin. Pour la Commission, M. BANGEMANN n'a pu en reprendre que trois, plutôt modestes dans leur portée, et s'est opposé en particulier à la prolongation du délai de prescription des créances telle que proposée par la commission compétente, à la prééminence des créances dues au budget communautaire qui pose de sérieux problèmes juridiques et au maintien définitif du principe de remboursement de frais entre Etats membres. Tous les amendements proposés par le rapporteur ont été adoptés par la plénière à une large majorité.</j.0:comment>
    <j.0:event_reported_by_person rdf:resource="http://publications.europa.eu/resource/agent/Otto%20BARDONG"/>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A4/1999/9</j.0:document_reference>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/REP_R1_byEP_CMT"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/133459"/>
    <j.0:event_legal_gets_report_of_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP_CONT"/>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-01-19</j.0:event_date>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/133459"/>
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A4/1999/9</j.0:event_legal_document_reference>
  </rdf:Description>
