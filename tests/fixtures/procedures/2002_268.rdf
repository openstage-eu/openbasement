  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/178131.348378">
    <j.0:event_legal_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOC_2003_095_R_0027_01"/>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BULLETIN/2003/1/-2/1.4.50</j.0:document_reference>
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">JO C/2003/95/27</j.0:event_legal_document_reference>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-02-26</j.0:event_date>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/178131"/>
    <j.0:event_legal_comment xml:lang="en">Le Comité approuve les modifications proposées et surtout l'approche relative aux exportations, soumises à une autorisation spécifique et à des contrôles rigoureux afin de réduire les émissions des substances appauvrissant la couche d'ozone. Le CESE considère important de mettre au point des mécanismes visant à encourager le remplacement des produits critiqués et financer des programmes de recherche sufisamment approfondis pour démontrer la valeur ajoutée des produits de substitutio</j.0:event_legal_comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:event_legal_uses_concept_mode_decision rdf:resource="http://publications.europa.eu/resource/authority/fd_606/100040"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/OPI_byEESC"/>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avis du Comité économique et social européen</j.0:type>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-02-26</j.0:date>
    <j.2:build_info>cdm:CDM_2.1.7  tdm:1523  xslt:3945 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:1.1.9 builddate:13/02/2014 11:45:43</j.2:build_info>
