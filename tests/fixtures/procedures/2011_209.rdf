    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/celex/52011PC0481"/>
    <j.0:dossier_title xml:lang="mt">Proposta għal REGOLAMENT TAL-PARLAMENT EWROPEW U TAL-KUNSILL li jemenda r-Regolament tal-Kunsill (KE) Nru 1698/2005 fir-rigward ta' ċerti dispożizzjonijiet marbutin mal-ġestjoni finanzjarja għal ċerti Stati Membri li għaddejjin minn diffikultajiet serji marbutin mal-istabbiltà finanzjarja tagħhom jew li jinsabu mhedda mit-tali diffikultajiet</j.0:dossier_title>
