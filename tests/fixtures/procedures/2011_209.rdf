    <j.0:dossier_title xml:lang="pt">Proposta de REGULAMENTO DO PARLAMENTO EUROPEU E DO CONSELHO que altera o Regulamento (CE) n.º 1698/2005 do Conselho no que diz respeito a determinadas disposições relacionadas com a gestão financeira para certos Estados Membros confrontados ou ameaçados com graves dificuldades de estabilidade financeira</j.0:dossier_title>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/200731.415346"/>
