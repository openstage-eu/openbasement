    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/procedure/NLE"/>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/1041958.2014-10-23_PUB_OJ"/>
    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12012E218"/>
    <j.0:title xml:lang="fr">Proposition de&amp;#13;
DÉCISION DU CONSEIL&amp;#13;
relative à la position à adopter par l'Union européenne au sein du conseil de stabilisation&amp;#13;
et d'association institué par l’accord de stabilisation et d’association entre les&amp;#13;
Communautés européennes et leurs États membres, d’une part, et la République du&amp;#13;
Monténégro, d’autre part, en ce qui concerne le remplacement du protocole n° 3 à cet&amp;#13;
accord, relatif à la définition de la notion de «produits originaires» et aux méthodes de&amp;#13;
coopération administrative, par un nouveau protocole qui, pour ce qui est des règles&amp;#13;
d'origine, fait référence à la convention régionale sur les règles d'origine paneuroméditerranéennes</j.0:title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/CSST_2014_9973_0000_0000_0000"/>
    <j.0:dossier_adopted-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</j.0:dossier_adopted-proposal>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/1041958.1217727"/>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/1041958.1217727"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#dossier"/>
    <j.0:dossier_title xml:lang="fr">Proposition de&amp;#13;
DÉCISION DU CONSEIL&amp;#13;
relative à la position à adopter par l'Union européenne au sein du conseil de stabilisation&amp;#13;
et d'association institué par l’accord de stabilisation et d’association entre les&amp;#13;
Communautés européennes et leurs États membres, d’une part, et la République du&amp;#13;
Monténégro, d’autre part, en ce qui concerne le remplacement du protocole n° 3 à cet&amp;#13;
accord, relatif à la définition de la notion de «produits originaires» et aux méthodes de&amp;#13;
coopération administrative, par un nouveau protocole qui, pour ce qui est des règles&amp;#13;
d'origine, fait référence à la convention régionale sur les règles d'origine paneuroméditerranéennes</j.0:dossier_title>
    <j.0:dossier_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12012E218"/>
