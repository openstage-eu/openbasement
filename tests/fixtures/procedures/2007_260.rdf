    <j.0:dossier_is_about_concept_type_dossier rdf:resource="http://publications.europa.eu/resource/authority/fd_612/1260"/>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/196479.389612"/>
    <j.0:dossier_title xml:lang="bg">Предложение за РЕГЛАМЕНТ НА ЕВРОПЕЙСКИЯ ПАРЛАМЕНТ И СЪВЕТА относно предоставянето на статистически данни за номиналния улов на държавите-членки, които извършват риболов в зони извън северната част на Атлантическия океан  (преработена версия)</j.0:dossier_title>
    <j.0:title xml:lang="es">Propuesta de REGLAMENTO DEL PARLAMENTO EUROPEO Y DEL CONSEJO sobre presentación de estadísticas de capturas nominales por los Estados miembros que faenen en determinadas zonas distintas de las del Atlántico Norte  (Versión refundida)</j.0:title>
    <j.0:procedure_code_interinstitutional_has_type_concept_type_procedure_code_interinstitutional rdf:resource="http://publications.europa.eu/resource/authority/procedure/COD"/>
