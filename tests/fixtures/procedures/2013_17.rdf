    <j.0:dossier_title xml:lang="lv">Priekšlikums PADOMES ĪSTENOŠANAS REGULA, ar ko uzliek galīgo antidempinga maksājumu dažu sagatavotu vai konservētu Ķīnas Tautas Republikas izcelsmes citrusaugļu (proti, mandarīnu utt.) importam</j.0:dossier_title>
    <j.0:based_on rdf:resource="http://publications.europa.eu/resource/celex/12012E%2FTXT"/>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOL_2013_049_R_0029_01"/>
    <j.0:title xml:lang="lt">Pasiūlymas TARYBOS ĮGYVENDINIMO REGLAMENTAS kuriuo tam tikrų Kinijos Liaudies Respublikos kilmės paruoštų arba konservuotų citrusinių vaisių (mandarinų ir kt.) importui nustatomas galutinis antidempingo muitas</j.0:title>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/celex/32013R0158"/>
