    <j.0:title xml:lang="pt">Proposta de DIRECTIVA DO PARLAMENTO EUROPEU E DO CONSELHO que altera a Directiva 77/91/CEE do Conselho, no que respeita à constituição da sociedade anónima, bem como à conservação e às modificações do seu capital social </j.0:title>
    <j.0:reference_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2004/0256/COD</j.0:reference_procedure>
