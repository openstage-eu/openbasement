    <j.0:dossier_title xml:lang="pl">Wniosek dotyczący DYREKTYWY PARLAMENTU EUROPEJSKIEGO I RADY zmieniającej dyrektywę Rady 77/91/EWG w sprawie tworzenia spółek akcyjnych i utrzymywania oraz zmian wysokości ich kapitału </j.0:dossier_title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/oj/JOL_2006_264_R_0032_01"/>
