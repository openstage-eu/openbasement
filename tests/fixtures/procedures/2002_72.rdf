    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EESC"/>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CESE/2002/1027</j.0:document_reference>
    <j.0:event_legal_comment xml:lang="en">L'avis, essentiellement favorable à la proposition de la Commission, a été adopté par 83 voix pour, 75 contre et 12 abstentions (tandis que le contre-avis du groupe I a été rejeté par 82 oui et 90 non), ce qui reflète un contraste de principe, essentiellement entre les groupes employeurs et travailleurs.</j.0:event_legal_comment>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_606/100040"/>
