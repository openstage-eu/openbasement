    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20181026-18; environment: PROD; newCERES: 3.23.0; IMMC2CDM: 2.8.0; rules: oj/rules-oj.xml#44552#2018-10-10; builddate: 2018-10-26T00:54:29.528;</j.2:build_info>
