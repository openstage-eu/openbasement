    <j.0:based_on rdf:resource="http://publications.europa.eu/resource/celex/11997E133"/>
    <j.0:dossier_title xml:lang="pt">Proposta de DECISÃO DO CONSELHO relativa à posição a adoptar pela Comunidade no Conselho de Associação criado pelo Acordo Europeu entre as Comunidades Europeias e os seus Estados-Membros, por um lado, e a República da Lituânia, por outro, no que diz respeito à melhoria do regime de trocas comerciais aplicável aos produtos agrícolas transformados, previsto no protocolo n.º 2 do Acordo Europeu entre as Comunidades Europeias e a República da Lituânia</j.0:dossier_title>
