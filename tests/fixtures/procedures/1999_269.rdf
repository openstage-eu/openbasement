    <j.2:build_info>cdm:3840  tdm:1523  xslt:3886 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:3886 builddate:19/07/2012 17:40:38</j.2:build_info>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/153339"/>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:comment xml:lang="fr">The Commission accepted one amendment i.e. to introduce a more reliable testing method when available and one amendment in principle i.e. to add further product categories to the example list and to exempt handmade oriental carpets from the Directive, however not temporarily. The Commission rejected the amendments that would extend the scope. Also the amendment introducing a second testing method was rejected.</j.0:comment>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/153339"/>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/153339"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:type>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-09-07</j.0:date>
    <j.0:event_legal_comment xml:lang="fr">The Commission accepted one amendment i.e. to introduce a more reliable testing method when available and one amendment in principle i.e. to add further product categories to the example list and to exempt handmade oriental carpets from the Directive, however not temporarily. The Commission rejected the amendments that would extend the scope. Also the amendment introducing a second testing method was rejected.</j.0:event_legal_comment>
    <j.0:event_legal_has_remark_concept_type_remark rdf:resource="http://publications.europa.eu/resource/authority/fd_603/1235"/>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-09-07</j.0:event_legal_date>
