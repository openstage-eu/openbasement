  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/150903">
    <j.0:title xml:lang="da">Forslag til RÅDETS DIREKTIV om gennemførelse af princippet om ligebehandling af alle uanset race eller etnisk oprindelse</j.0:title>
    <j.0:dossier_pending-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:dossier_pending-proposal>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/150903.301014"/>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/150903.287538"/>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/150903.302028"/>
    <j.0:dossier_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/11997E013"/>
    <j.0:dossier_produces_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/32000L0043"/>
    <j.0:comment xml:lang="fr">Cette proposition de directive fait partie d'une série de mesures visant à donner un effet utile à l'article 13 du Traité d'Amsterdam concernant la lutte contre la discrimination (COM(1999)564 final). Elle a pour objectif d'établir un cadre général pour le respect, au sein de l'Union européenne, du principe d'égalité de traitement sans distinction de race ou d'origine ethnique. Elle vient compléter la législation existante sur l'égalité de traitement entre hommes et femmes.</j.0:comment>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/150903.297505"/>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/150903.302028"/>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/150903.302689"/>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/150903.297326"/>
    <j.0:title xml:lang="sv">Förslag till RÅDETS DIREKTIV om genomförandet av principen om likabehandling av enskilda personer oavsett ras eller etniskt ursprung</j.0:title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/comnat/COM_1999_0566_FIN"/>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/150903.302689"/>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/150903.302148"/>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/celex/51999AR0513%2803%29"/>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/150903.302280"/>
    <j.0:dossier_title xml:lang="fi">Ehdotus NEUVOSTON DIREKTIIVIKSI rodusta tai etnisestä alkuperästä riippumattoman yhtäläisen kohtelun periaatteen täytäntöönpanosta</j.0:dossier_title>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/150903.301014"/>
    <j.0:reference_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1999/0253/CNS</j.0:reference_procedure>
