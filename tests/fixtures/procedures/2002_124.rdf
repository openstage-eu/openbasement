  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/174179.348372">
    <j.0:comment xml:lang="en">Sur l'ensemble de l'avis, les articles de la proposition de directive sont approuvés globalement par le CESE qui constate toutefois la multiplication des textes européens relatifs à l'assurance automobile et demande, par conséquent, que la Commission propose qu'une future directive regroupe l'ensemble des directives précédentes (72/166/CEE, 84/5/CEE, 88/357/CEE, 90/232/CEE, 2000/26/CE). </j.0:comment>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/174179"/>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_606/100040"/>
