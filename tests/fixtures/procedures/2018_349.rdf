    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/procedure-event/2018_349.2018-10-08_DIS_byCONSIL"/>
    <j.0:title xml:lang="sl">Predlog SKLEP SVETA o sklenitvi Sporazuma o partnerstvu o trajnostnem ribištvu med Evropsko unijo in Kraljevino Maroko, njegovega protokola o izvajanju ter izmenjave pisem, priloženih Sporazumu</j.0:title>
