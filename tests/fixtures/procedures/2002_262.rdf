  <rdf:Description rdf:about="http://publications.europa.eu/resource/cellar/b9d240d2-d2f5-11e1-905c-01aa75ed71a1.0002">
    <owl:sameAs rdf:resource="http://publications.europa.eu/resource/pegase/177670.341914"/>
