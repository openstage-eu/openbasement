  <rdf:Description rdf:nodeID="A1">
    <j.2:comment_on_legal_basis>P3L2</j.2:comment_on_legal_basis>
    <j.2:sentence>1</j.2:sentence>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
