    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:event_legal_type>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:event_legal_uses_concept_type_decision rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:comment xml:lang="en">La Commission peut soutenir seulement quatre des 21 amendements adoptés par le Parlement européen, à savoir ceux qui sont compatibles avec l'article 280 ainsi qu'avec l'objectif de la proposition de la Commission. Tous les autres amendements ne sont pas retenus pour les motifs que soit ils ne sont pas couverts par l'article 280, soit ils ne correspondent pas aux objectifs poursuivis par la Commission et risqueraient ainsi de retarder les négociations au Conseil qui s'avèrent déjà très difficiles.</j.0:comment>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/164800"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:event_legal_comment xml:lang="en">La Commission peut soutenir seulement quatre des 21 amendements adoptés par le Parlement européen, à savoir ceux qui sont compatibles avec l'article 280 ainsi qu'avec l'objectif de la proposition de la Commission. Tous les autres amendements ne sont pas retenus pour les motifs que soit ils ne sont pas couverts par l'article 280, soit ils ne correspondent pas aux objectifs poursuivis par la Commission et risqueraient ainsi de retarder les négociations au Conseil qui s'avèrent déjà très difficiles.</j.0:event_legal_comment>
    <j.2:build_info>cdm:CDM_2.1.7  tdm:1523  xslt:3945 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:1.1.9 builddate:13/02/2014 10:16:59</j.2:build_info>
