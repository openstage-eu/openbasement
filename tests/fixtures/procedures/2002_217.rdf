    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BULLETIN/2003/12/1.3.98</j.0:event_legal_document_reference>
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">JO C/2003/95/6</j.0:event_legal_document_reference>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/oj/JOC_2003_095_R_0006_01"/>
    <j.0:event_contains_work rdf:resource="http://publications.europa.eu/resource/celex/52003AE0277"/>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EESC"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:event_legal_contains_work rdf:resource="http://publications.europa.eu/resource/celex/52003AE0277"/>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BULLETIN/2003/12/1.3.98</j.0:document_reference>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avis du Comité économique et social européen</j.0:type>
    <j.0:comment xml:lang="en">Le Comité se félicite de la proposition de règlement qui a pour objectif d'établir les mesures harmonisées de contrôle et de surveillance de certaines substances chimiques fréquemment utilisées dans la fabrication de stupéfiants illicites, a été pleinement appuyé par le Comité. Il se prononce également pour l'application uniforme de la législation communautaire dans ce domaine afin d'éviter tout détournement des précurseurs de drogues en vue de la fabrication de drogues illicites. </j.0:comment>
    <j.0:event_legal_uses_concept_mode_decision rdf:resource="http://publications.europa.eu/resource/authority/fd_606/100040"/>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_606/100040"/>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avis du Comité économique et social européen</j.0:event_legal_type>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/176031"/>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BULLETIN/2003/1/2/1.4.26</j.0:document_reference>
