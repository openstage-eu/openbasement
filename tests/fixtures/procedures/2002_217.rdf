  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/176031.348841">
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:comment xml:lang="en">The Commission can accept amendment 1, which proposes the inclusion of a new recital 4a, making explicit the importance of the new instrument in the context of an EU that will comprise, from next year, 25 Member States and cannot accept amendments :Amendment 2 would require a yearly updating of the list of non-scheduled substances subject to voluntary monitoring measures by operators and Amendment 3 would oblige Member States to send an annual report to the Commission on implementing measures, although the Regulation will only be implemented once by each Member State.</j.0:comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:event_legal_uses_concept_type_decision rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-03-11</j.0:event_legal_date>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-03-11</j.0:event_date>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/176031"/>
    <j.0:event_legal_comment xml:lang="en">The Commission can accept amendment 1, which proposes the inclusion of a new recital 4a, making explicit the importance of the new instrument in the context of an EU that will comprise, from next year, 25 Member States and cannot accept amendments :Amendment 2 would require a yearly updating of the list of non-scheduled substances subject to voluntary monitoring measures by operators and Amendment 3 would oblige Member States to send an annual report to the Commission on implementing measures, although the Regulation will only be implemented once by each Member State.</j.0:event_legal_comment>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/176031"/>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/176031"/>
