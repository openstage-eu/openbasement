    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20180704-3732; environment: PROD; newCERES: 3.20.3; IMMC2CDM: 2.8.0; rules: preleg/rules-consil.xml#39852#2018-05-06; builddate: 2018-07-04T17:06:40.734;</j.2:build_info>
