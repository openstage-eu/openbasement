    <j.0:dossier_title xml:lang="nl">VOORSTEL VOOR EEN GEMEENSCHAPPELIJK OPTREDEN WAARTOE DOOR DE RAAD IS BESLOTEN OP GROND VAN ARTIKEL K. 3, LID 2, ONDER B) VAN HET VERDRAG BETREFFENDE DE EUROPESE UNIE, INZAKE TIJDELIJKE BESCHERMING VAN ONTHEEMDEN</j.0:dossier_title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/oj/JOC_1998_268_R_0013_01"/>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/11725.261909"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1997-03-05</j.0:date>
