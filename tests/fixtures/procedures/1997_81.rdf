    <j.0:reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1997/0081/CNS</j.0:reference>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/11725.14232"/>
    <j.0:procedure_code_interinstitutional_reference_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1997/0081/CNS</j.0:procedure_code_interinstitutional_reference_procedure>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/11725.243104"/>
    <j.0:dossier_comment xml:lang="fr">Dans le cadre de la révision de la proposition sur la protection temporaire des personnes déplacées, la Commission propose de disjoindre les 2 aspects : procédure d'octroi d'une protection temporaire et droits minimaux pour les bénéficiaires, et de leurs consacrer deux instruments juridiques distincts. Cette approche a pour objet de favoriser l'adoption de la proposition sur la protection temporaire. Le volet sur les mécanismes de solidarité fait donc l'objet d'une nouvelle initiative (COM(1998)372FINAL - 98/0222/CNS)</j.0:dossier_comment>
    <j.0:dossier_initiated_by_act_preparatory rdf:resource="http://publications.europa.eu/resource/celex/51997PC0093"/>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/11725.261910"/>
    <j.0:title xml:lang="fr">Proposition adressée au CONSEIL EN VUE D'UNE ACTION COMMUNE FONDEE SUR L'ARTICLE K. 3 2(B) DU TRAITE SUR L'UNION EUROPEENNEconcernant la protection temporaire des personnes deplacées</j.0:title>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/11725.10495"/>
