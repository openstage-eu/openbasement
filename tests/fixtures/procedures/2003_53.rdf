    <j.0:pending-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:pending-proposal>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/181611.349520"/>
    <j.0:title xml:lang="sv">Förslag till RÅDETS BESLUT om ingående av avtal genom skriftväxling mellan Europeiska gemenskapen och, å ena sidan, Barbados, Belize, Republiken Kongo, Fiji, Republiken Guyana, Republiken Elfenbenskusten, Jamaica, Republiken Kenya, Republiken Madagaskar, Republiken Malawi, Republiken Mauritius, Republiken Surinam, Saint Christopher och Nevis, Konungariket Swaziland, Republiken Tanzania, Republiken Trinidad och Tobago, Republiken Uganda, Republiken Zambia samt Republiken Zimbabwe, och, å andra sidan, Republiken Indien om garantipriser för rörsocker under leveransperioderna 2001/02 och 2002/03</j.0:title>
