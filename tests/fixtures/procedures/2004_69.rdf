    <j.0:dossier_title xml:lang="nl">MEDEDELING VAN DE COMMISSIE AAN DE RAAD EN HET EUROPEES PARLEMENT over bepaalde maatregelen die moeten worden genomen op het gebied van de bestrijding van terrorisme en andere ernstige vormen van criminaliteit, met name om de uitwisseling van informatie te verbeteren</j.0:dossier_title>
    <j.0:dossier_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12002M029"/>
