    <j.0:procedure_code_interinstitutional_year_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2010</j.0:procedure_code_interinstitutional_year_procedure>
    <j.0:dossier_title xml:lang="cs">Návrh ROZHODNUTÍ RADY o uzavření nového Protokolu, kterým se stanoví rybolovná práva a finanční příspěvek podle Dohody o partnerství v odvětví rybolovu mezi Evropským společenstvím a Komorským svazem</j.0:dossier_title>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/199754.2011-05-21_PUB_OJ"/>
