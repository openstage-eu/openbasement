  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/199163">
    <j.0:title xml:lang="pt">Proposta de DECISÃO DO CONSELHO relativa à posição a adoptar no âmbito do Comité Misto do EEE   sobre uma alteração do Protocolo n.º 31 do Acordo EEE  relativo à cooperação em domínios específicos não abrangidos pelas quatro liberdades (ISA)</j.0:title>
    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/31994R2894"/>
    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12010E218"/>
