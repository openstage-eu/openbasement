    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/OPI_byCOR"/>
    <j.0:comment xml:lang="en">Le Comité a approuvé  un avis favorable au projet d'Espace ferroviaire européen intégré. Suivant l'opinion exprimée par le rapporteur, il a demandé de retarder (sur ce point il y a eu un bref débat) la mise en oeuvre des propositions de la Commission pour permettre aux régions les plus faibles de s'y préparer. </j.0:comment>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/OPI_byCOR"/>
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BULLETIN/2002/10/1.4.52</j.0:document_reference>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COR"/>
