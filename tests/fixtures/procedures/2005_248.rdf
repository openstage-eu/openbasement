    <j.0:dossier_title xml:lang="es">Propuesta de REGLAMENTO DEL PARLAMENTO EUROPEO Y DEL CONSEJO relativo a la producción y al desarrollo de estadísticas sobre educación y aprendizaje permanente</j.0:dossier_title>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/193627.387885"/>
