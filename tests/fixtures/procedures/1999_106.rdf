    <j.0:dossier_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/11997E310"/>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/145466.301679"/>
