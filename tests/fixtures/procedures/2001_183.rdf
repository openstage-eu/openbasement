    <j.0:dossier_title xml:lang="nl">Voorstel voor een BESLUIT VAN DE RAAD betreffende het standpunt van de Gemeenschap in de Associatieraad tussen de Europese Gemeenschappen en hun lidstaten, enerzijds, en Hongarije, anderzijds, inzake de overdracht van bevoegdheden voor het beheer van het Protocol inzake overeenstemmingsbeoordeling en de aanvaarding van industrieproducten</j.0:dossier_title>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/167060.330418"/>
