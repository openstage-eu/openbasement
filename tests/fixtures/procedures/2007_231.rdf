    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOC_2008_009_R_0002_01"/>
    <j.0:title xml:lang="sk">Návrh ROZHODNUTIA RADY o podpísaní a predbežnom uplatňovaní protokolu k Euro-stredozemskej dohode medzi Európskymi spoločenstvami a ich členskými štátmi na jednej strane a Jordánskym hášimovským kráľovstvom na strane druhej na účely zohľadnenia pristúpenia Bulharskej republiky a Rumunska k Európskej únii</j.0:title>
    <j.0:dossier_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12006E300"/>
    <j.0:title xml:lang="ro">Propunere de DECIZIE A CONSILIULUI privind semnarea şi aplicarea cu titlu provizoriu a unui protocol la Acordul euromediteraneean între Comunităţile Europene şi statele membre ale acestora, pe de o parte, şi Regatul Haşemit al Iordaniei, pe de altă parte, pentru a ţine seama de aderarea Republicii Bulgaria şi a României la Uniunea Europeană</j.0:title>
    <j.0:reference_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2007/0231/NLE</j.0:reference_procedure>
