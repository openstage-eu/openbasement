  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/163321.329164">
    <j.2:build_info>cdm:CDM_2.1.7  tdm:1523  xslt:3945 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:1.1.9 builddate:13/02/2014 10:00:57</j.2:build_info>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-12-13</j.0:event_date>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:event_legal_comment xml:lang="en">La proposition initiale ayant été modifiée par oral, la Commission estime inopportun d'élaborer par écrit une seconde proposition modifiée, eu égard à la nécessité de poursuivre rapidement la procédure d'adoption. Dans cette même perspective, les vues de la Commission concernant l'Accord politique seront précisées dans la Communication qu'elle adoptera au regard de la future Position commune du Conseil</j.0:event_legal_comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-12-13</j.0:event_legal_date>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1020"/>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-12-13</j.0:date>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:event_legal_type>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/163321"/>
