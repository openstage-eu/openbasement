  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/11575">
    <j.0:title xml:lang="da">FORSLAG TIL RAADETS AFGOERELSE OM FAELLESSKABETS FAELLES HOLDNING I ASSOCIERINGSRAADET EF-TYRKIET VERDROERENDE EN MIDLERTIDIG UNDTAGELSESORDNING FOR TYRKIETS ANVENDELSE AF DEN FAELLES TOLDTARIF OVER FOR TREDJELANDE</j.0:title>
    <j.0:dossier_title xml:lang="pt">PROPOSTA DE DECISAO DO CONSELHO RELATIVA A ADOPCAO PELA COMUNIDADE,NO AMBITO DO CONSELHO DE ASSOCIACAO CE-TURQUIA,DE UMA POSICAO COMUM NO QUE RESPEITA A UM REGIME PROVISORIO DE DERROGACAO A APLICACAO,PELA TURQUIA DA PANTA EXTERNA COMUM EM RELACAO AOS PAISES TERCEIROS</j.0:dossier_title>
    <j.0:title xml:lang="pt">PROPOSTA DE DECISAO DO CONSELHO RELATIVA A ADOPCAO PELA COMUNIDADE,NO AMBITO DO CONSELHO DE ASSOCIACAO CE-TURQUIA,DE UMA POSICAO COMUM NO QUE RESPEITA A UM REGIME PROVISORIO DE DERROGACAO A APLICACAO,PELA TURQUIA DA PANTA EXTERNA COMUM EM RELACAO AOS PAISES TERCEIROS</j.0:title>
    <j.0:dossier_comment xml:lang="fr">LA COMMISSION CONSIDERE QUE LA BASE JURIDIQUE APPROPRIEE POUR LA DECISION DU CONSEIL D'ASSOCIATION,QUI PORTE EXCLUSIVEMENT SUR LES QUESTIONS DE TARIF DOUANIER,EST L'ART. 113CE. LE CONSEIL EST APPELE A STATUER LE PLUS RAPIDEMENT POSSIBLE.  LE CONSEIL A APPROUVE,LORS DE SA 1853EME SESSION DU 12/06/1995, LES PROJETS DE DECISION 1/95 ET 2/95 (SEC/95/539FINAL ET SEC/95/541FINAL). LA DECISION SERA ADOPTEE FORMELLEMENT PAR LE CONSEIL ET PAR PROCEDURE ECRITE DU CONSEIL D'ASSOCIATION DES RECEPTION DE L'AVIS CONFORME DU PE</j.0:dossier_comment>
    <j.0:procedure_code_interinstitutional_year_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1995</j.0:procedure_code_interinstitutional_year_procedure>
