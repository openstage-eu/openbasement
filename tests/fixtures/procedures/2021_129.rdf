    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20210614-2443; environment: PROD; CERES: 4.13.3; IMMC2CDM: 3.2.2; rules: preleg/rules-consil.xml#56614#2020-05-29T09:45:21; builddate: 2021-06-14T17:45:42.328;</j.2:build_info>
