    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/103451.144543"/>
    <j.0:dossier_comment xml:lang="fr">LE CONSEIL EST APPELE A STATUER SUR CETTE PROPOSITION EN AVRIL 1993. DANS CETTE PERSPECTIVE, LE PE ET LA COUR DES COMPTES SONT APPELES A RENDRE LEUR AVIS EN FEVRIER 1993. EXTRAIT DU TEXTE DES PREVISIONS DE CALENDRIER DE LA LETTRE DE TRANSMISSION.LE CONSEIL A ACCEPTE LA CONCERTATION ET UNE ORIENTATION COMMUNE A ETE DEGAGEE LE 17/11/1995 LORS DE LA 1882EME SESSION DU CONSEIL. LE PE A APPROUVE LA DECISION SUR LES RESULTATS DE LA PROCEDURE DE CONCERTATION LORS DE SA SESSION DU 15/03/1996 (REF.PUB.=JOCE C 096 DU 01/04/1996 P.335.</j.0:dossier_comment>
    <j.0:type_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM</j.0:type_reference>
