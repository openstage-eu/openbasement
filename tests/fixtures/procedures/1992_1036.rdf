    <j.0:dossier_title xml:lang="fr">PROPOSITION DE REGLEMENT (CEE) DU CONSEILMODIFIANT LE REGLEMENT DU CONSEIL 1552/89 PORTANT APPLICATION DE LA DECISION 88/376/CEE, EURATOM RELATIVE AU SYSTEME DES RESSOURCES PROPRES DES COMMUNAUTES</j.0:dossier_title>
