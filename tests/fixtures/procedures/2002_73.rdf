  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/172643.339393">
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BULLETIN/2002/9/1.4.70</j.0:document_reference>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avis Comité économique et social</j.0:event_legal_type>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-09-18</j.0:event_date>
    <j.0:event_legal_comment xml:lang="en">Avis approuvé par 129 voix pour, 1 contre et 5 abstentions. Le CES soutient la proposition de la Commission qui vise à réformer la procédure d'autorisation pour les additifs alimentaires et à supprimer les quatre antibiotiques encore  le marché. Il considère qu'elle est un compromis acceptable et qu'aucun retard supplémentaire ne doit être accepté. </j.0:event_legal_comment>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/OPI_byESC"/>
    <j.0:reported_by rdf:resource="http://publications.europa.eu/resource/agent/Cornelius%20SCULLY"/>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/OPI_byESC"/>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/172643"/>
