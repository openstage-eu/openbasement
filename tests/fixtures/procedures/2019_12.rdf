  <rdf:Description rdf:nodeID="A15">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="http://publications.europa.eu/resource/procedure-event/2019_12.2019-01-31_ADP_byCOM"/>
    <j.3:article rdf:datatype="http://www.w3.org/2001/XMLSchema#string">82</j.3:article>
    <j.3:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20190131-1204; environment: PROD; newCERES: 3.23.2; IMMC2CDM: 2.8.0; rules: preleg/rules-com.xml#40111#2018-06-04; builddate: 2019-01-31T10:51:27.123;</j.3:build_info>
