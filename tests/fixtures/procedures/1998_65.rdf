  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/112977">
    <j.0:title xml:lang="da">Forslag til RÅDETS DIREKTIV om udvidelse af Rådets direktiv 97/81/EF af 15. december 1997 om rammeaftalen verdrørende deltidarbejde, der er indgået af UNICE, CEEP og EFS, til at omfatte Det Forenede Kongerige Storbritannien og Nordirland</j.0:title>
    <j.0:dossier_pending-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:dossier_pending-proposal>
    <j.0:is_about rdf:resource="http://publications.europa.eu/resource/authority/fd_612/1130"/>
    <j.0:identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pegase:112977</j.0:identifier>
    <j.0:number_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">84 - 1</j.0:number_reference>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/oj/JOC_1998_138_R_0084_01"/>
    <j.0:dossier_year_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1998</j.0:dossier_year_reference>
    <j.0:comment xml:lang="nl">Gewijzigde richtl.: PB L 14/20.1.98</j.0:comment>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/112977.182181"/>
    <j.0:type_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM</j.0:type_reference>
    <j.0:comment xml:lang="sv">Ändrat dir.: EGT L 14/20.1.98</j.0:comment>
    <j.0:procedure_code_interinstitutional_year_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1998</j.0:procedure_code_interinstitutional_year_procedure>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/112977.182178"/>
    <j.0:title xml:lang="es">Propuesta de DIRECTIVA DEL CONSEJO relativa a la ampliación de la Directiva 97/81/CE del Consejo, de 15 de diciembre de 1997, relativa al Acuerdo marco sobre el trabajo a tiempo parcial concluido por la UNICE, el CEEP y la CES, al Reino Unido de Gran Bretaña e Irlanda del Norte.</j.0:title>
    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/11992E100"/>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/uriserv/COM.1998.0084(01).FIN"/>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOC_1998_123_R_0013_01"/>
    <j.0:dossier_comment xml:lang="it">Dir. modificata: GU L 14/20.1.98</j.0:dossier_comment>
    <j.0:based_on rdf:resource="http://publications.europa.eu/resource/celex/11992E100"/>
    <j.0:comment xml:lang="es">Dir. modificada: DO L 14/20.1.98</j.0:comment>
    <j.0:title xml:lang="it">Proposta di DIRETTIVA DEL CONSIGLIO relativa all'estensione della direttiva 97/81/CE del Consiglio, del 15 dicembre 1997, relativa all'accordo quadro sul lavoro a tempo parziale concluso dall'UNICE, dal CEEP e dalla CES, al Regno Unito di Gran Bretagna e Irlanda del Nord</j.0:title>
    <j.0:dossier_adopted-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</j.0:dossier_adopted-proposal>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/112977.182179"/>
    <j.0:comment xml:lang="fr">La directive 97/81/CE adoptée le 15 décembre 1997 sur la base du protocole sur la politique sociale, n'est actuellement pas applicable au Royaume-Uni. A la suite de l'accord conclu lors du Conseil européen d'Amsterdam qui prévoit que le Royaume-Uni mettra en vigueur les directives arrêtées au titre du protocole sur la politique sociale, il a été décidé qu'une directive du Conseil fondée sur l'article 100 du traité serait la meilleure façon d'attribuer, dans chaque cas particulier, des effets juridiques à cet accord</j.0:comment>
    <j.0:withdrawn-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:withdrawn-proposal>
    <j.0:procedure_code_interinstitutional_number_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0065</j.0:procedure_code_interinstitutional_number_procedure>
    <j.0:dossier_comment xml:lang="da">Ændret dir.: EFT L 14/20.1.98</j.0:dossier_comment>
    <j.0:dossier_comment xml:lang="pt">Dir. alterada: JO L 14/20.1.98</j.0:dossier_comment>
