    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-05-14</j.0:event_date>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:event_legal_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en lecture unique</j.0:event_legal_type>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-05-14</j.0:event_legal_date>
    <j.0:event_legal_comment xml:lang="fr">Refus des amendements 1, 2 et 4 proposés par le PE étant donné qu'ils demandent à la Commission de fournir des informations que, de facto, la Commission envoie déjà au PE et au Conseil dans le cadre des accords inter-institutionnels. L'amendement 3 a été rejeté parce qu'il est contraire aux principes de la dimension internationale de la PCP. L'amendement 5 a été rejeté parce qu'il fait référence à un règlement du Conseil que les Etats membres sont déjà tenus à respecter.</j.0:event_legal_comment>
    <j.0:event_legal_uses_concept_type_decision rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1030"/>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/171160"/>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-05-14</j.0:date>
    <j.2:build_info>cdm:3840  tdm:1523  xslt:3886 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:3886 builddate:21/07/2012 00:24:25</j.2:build_info>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_RSI_byCOM"/>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en lecture unique</j.0:type>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1030"/>
    <j.0:comment xml:lang="fr">Refus des amendements 1, 2 et 4 proposés par le PE étant donné qu'ils demandent à la Commission de fournir des informations que, de facto, la Commission envoie déjà au PE et au Conseil dans le cadre des accords inter-institutionnels. L'amendement 3 a été rejeté parce qu'il est contraire aux principes de la dimension internationale de la PCP. L'amendement 5 a été rejeté parce qu'il fait référence à un règlement du Conseil que les Etats membres sont déjà tenus à respecter.</j.0:comment>
  </rdf:Description>
