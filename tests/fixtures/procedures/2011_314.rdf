    <j.0:event_legal_uses_concept_type_decision rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <j.0:comment xml:lang="en">The European Parliament resolution contains 16 amendments. 1) The Commission can accept in principle amendments 1, 2, 3, 4, 5, 12, 13 and 14. 2) The Commission cannot accept  (Amendment 7). 3) The Commission cannot accept the amendments (Amendment 10 and 11). 4) The Commission can neither accept the other (minor) amendments </j.0:comment>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en première lecture</j.0:event_legal_type>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2012-09-11</j.0:event_date>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R1_byCOM"/>
    <j.0:event_legal_comment xml:lang="en">The European Parliament resolution contains 16 amendments. 1) The Commission can accept in principle amendments 1, 2, 3, 4, 5, 12, 13 and 14. 2) The Commission cannot accept  (Amendment 7). 3) The Commission cannot accept the amendments (Amendment 10 and 11). 4) The Commission can neither accept the other (minor) amendments </j.0:event_legal_comment>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1025"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
