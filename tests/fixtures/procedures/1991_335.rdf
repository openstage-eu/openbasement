    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:comment xml:lang="fr">Au cours du Conseil des ministres de l'environnement des 8-9/06/1994, le Conseil a adopté une proposition modifiée, en la basant sur l'art. 130s,1CE (environnement, procédure de coopération), et non sur l'art. 100aCE (procédure de codécision). en raison de ce changement de base juridique, le Conseil a du reconsulter le Parlement.</j.0:comment>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Accord politique position commune du Conseil</j.0:type>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/AGR_COMPOS_byCONSIL"/>
