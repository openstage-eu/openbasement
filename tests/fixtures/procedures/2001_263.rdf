    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/169220.330213"/>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/169220.333895"/>
    <j.0:dossier_title xml:lang="pt">Proposta de DECISÃO DO CONSELHO relativa à posição a adoptar pela Comunidade no âmbito do Comité Misto respeitante à inserção do artigo 20º-A Separação de contas no Protocolo nº 3, relativo à definição da noção de produtos originários e aos métodos de cooperação administrativa, estabelecido no Acordo entre a Comunidade Europeia, por um lado, e o Governo da Dinamarca e o Governo Regional das Ilhas Faroé, por outro</j.0:dossier_title>
