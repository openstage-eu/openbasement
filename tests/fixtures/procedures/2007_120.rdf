  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/195886">
    <j.0:dossier_title xml:lang="ro">Propunere de DECIZIE A CONSILIULUI privind semnarea şi încheierea Acordului interimar privind comerţul şi aspectele legate de comerţ între Comunitatea Europeană, pe de o parte, şi Republica Muntenegru,  pe de altă parte,</j.0:dossier_title>
