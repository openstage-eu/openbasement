  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/186775.363000">
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_RSI_byCOM"/>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en lecture unique</j.0:event_legal_type>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_RSI_byCOM"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2004-03-31</j.0:date>
    <j.0:event_legal_comment xml:lang="en">The Commission can accept certain amendments in principle: amendments 6 (each MS to make a declaration identifying its issuing and executing authorities); 9 partially (right to no self-incrimination should be able to be claimed under laws of either issuing or executing MS); 10 partially (formalities required by issuing authority to be followed in the executing MS to be subject to the safeguards in Art. 12); and 13 (but as a recital: the subsequent use of the acquired evidence does not prejudice rights of the defence in subsequent proceedings). (Amendment numbers follow the 6.4.04 provisional version of Resolution &amp;#13;
</j.0:event_legal_comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:event_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/186775"/>
