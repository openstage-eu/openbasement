    <j.0:event_contains_work rdf:resource="http://publications.europa.eu/resource/celex/52004XC0109%2801%29"/>
    <j.0:comment xml:lang="en">La proposition de règlement du Conseil portant modification du règlement(CEE) n° 1911/91 relatif à l'application des dispositions du droit communautaire aux Canaries (COM/2001/76final CNS 2001/38) couvrant tant les aspects douaniers que fiscaux, la Commission a décidé de retirer la proposition COM/2000/891 afin de restaurer la concomittance entre les deux aspects</j.0:comment>
    <j.0:event_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOC_2004_005_R__01"/>
    <j.0:event_legal_comment xml:lang="en">La proposition de règlement du Conseil portant modification du règlement(CEE) n° 1911/91 relatif à l'application des dispositions du droit communautaire aux Canaries (COM/2001/76final CNS 2001/38) couvrant tant les aspects douaniers que fiscaux, la Commission a décidé de retirer la proposition COM/2000/891 afin de restaurer la concomittance entre les deux aspects</j.0:event_legal_comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
