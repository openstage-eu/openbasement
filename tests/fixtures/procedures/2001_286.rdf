  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/170024">
    <j.0:title xml:lang="fi">Ehdotus: NEUVOSTON PÄÄTÖS juuttia käsittelevän kansainvälisen tutkimusryhmän toimeksiantoa koskevan vuoden 2001 sopimuksen allekirjoittamisesta ja tekemisestä Euroopan yhteisön puolesta</j.0:title>
    <j.0:dossier_date_creation_legacy rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-12-06</j.0:dossier_date_creation_legacy>
    <j.0:dossier_type_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM</j.0:dossier_type_reference>
    <j.0:dossier_title xml:lang="sv">Förslag till RÅDETS BESLUT om undertecknande och ingående på Europeiska gemenskapens vägnar av 2001 års avtal om fastställande av instruktionen för Internationella studiegruppen för jute</j.0:dossier_title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/celex/52001PC0738"/>
    <j.0:title xml:lang="fr">Proposition de DÉCISION DU CONSEIL relative à la signature et à la conclusion au nom de la Communauté européenne de l'Accord portant mandat du Groupe d'Etude International du Jute 2001</j.0:title>
    <j.0:dossier_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/11997E133"/>
    <j.0:year_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2001</j.0:year_reference>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/170024.328727"/>
    <j.0:year_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2001</j.0:year_procedure>
    <j.0:title xml:lang="en">Proposal for a COUNCIL DECISION on the signing and conclusion on behalf of the Community of the Agreement establishing the terms of reference of the International Jute Study Group, 2001</j.0:title>
    <j.0:procedure_code_interinstitutional_reference_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2001/0286/ACC</j.0:procedure_code_interinstitutional_reference_procedure>
    <j.0:based_on rdf:resource="http://publications.europa.eu/resource/celex/11997E133"/>
    <j.0:title xml:lang="it">Proposta di DECISIONE DEL CONSIGLIO relativa alla firma e alla conclusione in nome della Comunità europea dell'Accordo relativo al mandato del Gruppo internazionale di studio sulla iuta del 2001</j.0:title>
    <j.0:comment xml:lang="en">Given that the International Study Group expressly excludes any financial instrument funded by its members and that any contributions from the EU Member States to the operating budget of the Study Group cannot of themselves justify the Member States' participation in the conclusion of the Agreement, the new Agreement establishing the terms of reference of the International Jute Study Group 2001 ought to be concluded by the Community. Consequently, under Article 133 of the Treaty establishing the European Community, this proposal for a Decision authorises the Commission to conclude, on behalf of the Community, the International Jute Study Group 2001.</j.0:comment>
    <j.0:date_creation_legacy rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-12-06</j.0:date_creation_legacy>
    <j.0:withdrawn-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:withdrawn-proposal>
