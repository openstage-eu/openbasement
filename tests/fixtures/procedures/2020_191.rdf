    <j.0:dossier_adopted-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</j.0:dossier_adopted-proposal>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/immc/ST%2010256%202020%20INIT"/>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/immc/ST%2010255%202020%20REV%201%20ADD%201"/>
    <j.0:procedure_code_interinstitutional_has_type_concept_type_procedure_code_interinstitutional rdf:resource="http://publications.europa.eu/resource/authority/procedure/NLE"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/procedure/NLE"/>
    <j.0:identifier rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">procedure:2020_191</j.0:identifier>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/procedure-event/2020_191.2020-09-21_DIS_byCONSIL"/>
    <j.0:title xml:lang="lv">Priekšlikums PADOMES LĒMUMS par nostāju, kas Eiropas Savienības vārdā jāieņem Apvienotajā komitejā, kura izveidota ar nolīgumu starp Eiropas Kopienu, no vienas puses, un Dānijas valdību un Farēru salu autonomijas valdību, no otras puses, attiecībā uz grozījumiem šā nolīguma 3. protokolā par jēdziena “noteiktas izcelsmes izstrādājumi” definīciju un administratīvās sadarbības metodēm</j.0:title>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/procedure-event/2020_191.2020-09-21_DIS_byCONSIL"/>
    <j.0:title xml:lang="es">Propuesta de DECISIÓN DEL CONSEJO relativa a la posición que debe adoptarse en nombre de la Unión Europea en el seno del Comité Mixto instituido en virtud del Acuerdo entre la Comunidad Europea, por una parte, y el Gobierno de Dinamarca y el Gobierno local de las Islas Feroe, por otra, por lo que se refiere a la modificación del Protocolo n.º 3 de dicho Acuerdo sobre la definición del concepto de «productos originarios» y los métodos de cooperación administrativa</j.0:title>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/procedure-event/2020_191.2020-08-26_DIS_byCONSIL"/>
    <j.0:title xml:lang="sk">Návrh ROZHODNUTIE RADY o pozícii, ktorá sa má zaujať v mene Európskej únie v spoločnom výbore zriadenom Dohodou medzi Európskym spoločenstvom na jednej strane a vládou Dánska a miestnou vládou Faerských ostrovov na strane druhej, pokiaľ ide o zmenu protokolu 3 k uvedenej dohode týkajúceho sa vymedzenia pojmu „pôvodné výrobky“ a metód administratívnej spolupráce</j.0:title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/immc/ST%2010255%202020%20INIT"/>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/immc/ST%2010255%202020%20REV%201"/>
    <j.0:dossier_initiated_by_act_preparatory rdf:resource="http://publications.europa.eu/resource/comnat/COM_2020_0394_FIN"/>
    <j.0:dossier_title xml:lang="el">Πρόταση ΑΠΟΦΑΣΗ ΤΟΥ ΣΥΜΒΟΥΛΙΟΥ σχετικά με τη θέση που πρέπει να ληφθεί εξ ονόματος της Ευρωπαϊκής Ένωσης στο πλαίσιο της Μεικτής Επιτροπής που έχει συσταθεί με τη συμφωνία μεταξύ της Ευρωπαϊκής Κοινότητας, αφενός, και της κυβέρνησης της Δανίας και της τοπικής κυβέρνησης των Νήσων Φερόε, αφετέρου, όσον αφορά την τροποποίηση του πρωτοκόλλου 3 της εν λόγω συμφωνίας, σχετικά με τον ορισμό της έννοιας «καταγόμενα προϊόντα» ή «προϊόντα καταγωγής» και τις μεθόδους διοικητικής συνεργασίας</j.0:dossier_title>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#procedure_code_interinstitutional"/>
    <j.0:based_on rdf:resource="http://publications.europa.eu/resource/celex/12016E207"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-24</j.0:date>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/procedure-event/2020_191.2020-09-25_DIS_byCONSIL"/>
    <j.0:dossier_type_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM</j.0:dossier_type_reference>
