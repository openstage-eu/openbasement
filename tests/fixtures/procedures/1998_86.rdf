  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/120549">
    <j.0:reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1998/0086/CNS</j.0:reference>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/celex/31998R1660"/>
    <j.0:title xml:lang="sv">Förslag till Rådets Förordning (EG) om antagande av det protokoll vari de fiskemöjligheter och den ekonomiska kompensation som föreskrivs i avtalet mellem Europeiska gemenskapen och Republiken Guineas om fiske utanför Guineas kust fastställs för tiden från och med den 1 januari 1998 till och med den 31 december 1999.</j.0:title>
    <j.0:pending-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:pending-proposal>
    <j.0:based_on rdf:resource="http://publications.europa.eu/resource/celex/11992E043"/>
