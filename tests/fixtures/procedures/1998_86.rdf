    <j.0:contains rdf:resource="http://publications.europa.eu/resource/oj/JOL_1998_211_R_0001_01"/>
    <j.0:dossier_identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pegase:120549</j.0:dossier_identifier>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.0:title xml:lang="nl">Voorstel voor een Verordening (EG) van de Raad betreffende de sluiting van het Protocol tot vaststelling van de vangstmogelijkheden en de financiële tegenprestatie, bedoeld in de Overeenkomst tussen de Europese Gemeenschap en de Regering van de Republiek Guinee inzake de visserij voor de kust van Guinee, voor de periode van 1 januari 1998 tot en met 31 december 1999.</j.0:title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/120549.194331"/>
