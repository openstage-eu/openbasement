    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R2_byCOM"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:comment xml:lang="fr">The European Parliament adopted 17 amendments. 3 amendments have been accepted by the Commission in full (Amendment 7, 13, 22), 10 have been accepted in part or in principle (Amendments 4, 14 and 26 to 33). The remaining 4 amendments (Amendment 1, first part of Amendment 10, first part of Amendment 12 and Amendment 25) cannot be accepted.. It is improbable that the Council will endorse all the amendments of the European Parliament. Conciliation will therefore be necessary.</j.0:comment>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R2_byCOM"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_R2_byCOM"/>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-06-13</j.0:date>
    <j.0:type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en deuxième lecture</j.0:type>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-06-13</j.0:event_legal_date>
    <j.0:event_legal_comment xml:lang="fr">The European Parliament adopted 17 amendments. 3 amendments have been accepted by the Commission in full (Amendment 7, 13, 22), 10 have been accepted in part or in principle (Amendments 4, 14 and 26 to 33). The remaining 4 amendments (Amendment 1, first part of Amendment 10, first part of Amendment 12 and Amendment 25) cannot be accepted.. It is improbable that the Council will endorse all the amendments of the European Parliament. Conciliation will therefore be necessary.</j.0:event_legal_comment>
  </rdf:Description>
