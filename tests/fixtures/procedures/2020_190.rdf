    <j.0:contains rdf:resource="http://publications.europa.eu/resource/procedure-event/2020_190.2020-12-07_ADP_FRM_byCONSIL"/>
    <j.0:based_on rdf:resource="http://publications.europa.eu/resource/celex/12016E207"/>
