    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/200851.413154"/>
    <j.0:title xml:lang="it">Proposta di DECISIONE DEL CONSIGLIO sulla posizione che l'Unione europea deve assumere all'interno del comitato per il commercio istituito dall'accordo di libero scambio tra l'Unione europea e i suoi Stati membri, da una parte, e la Repubblica di Corea, dall'altra, rispetto all'adozione del regolamento interno del comitato per il commercio e alla compilazione di un elenco di quindici persone per esercitare la funzione di arbitro</j.0:title>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/procedure/NLE"/>
    <j.0:date_creation_legacy rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2011-09-28</j.0:date_creation_legacy>
