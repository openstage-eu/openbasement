    <j.0:procedure_code_interinstitutional_year_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2022</j.0:procedure_code_interinstitutional_year_procedure>
    <j.0:dossier_title xml:lang="it">Proposta di DECISIONE DEL CONSIGLIO che stabilisce la posizione da adottare a nome dell'Unione in merito alla decisione dei partecipanti all'accordo sui crediti all'esportazione che beneficiano di sostegno pubblico di ampliare l'ambito di applicazione dell'intesa settoriale sui crediti all'esportazione per energie rinnovabili, attenuazione dei mutamenti climatici e adattamento ad essi e opere idrauliche</j.0:dossier_title>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#procedure_interinstitutional"/>
