    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/11398.13705"/>
    <j.0:comment xml:lang="fr">LES PROCEDURES DE CONCLUSION DE L'ACCORD DIFFERENT SELON LES DEUX COMMUNAUTES : LE CONSEIL CONCLUT L'ACCORD AU NOM DE LA CE, APRES AVIS CONFORME DU PE. LA COMMISSION, APRES AVIS CONFORME DU CONSEIL STATUANT A L'UNANIMITE, ET CONSULTATION DU COMITE CONSULTATIF CONCLUT L'ACCORD AU NOM DE LA CECA. LA SIGNATURE DE L'ACCORD DEVANT INTERVENIR EN JUIN, LE CONSEIL EST APPELE A APPROUVER L'ACCORD ET A AUTORISER LA SIGNATURE LE PLUS RAPIDEMENT POSSIBLE. IL EST APPELE ENSUITE A CONCLURE L'ACCORD APRES QUE LE PARLEMENT EUROPEEN AURA RENDU SON AVIS CONFORME. LORS DE SA 1864EME SESSION DU 17/07/1995, LE CONSEIL A APPROUVE LES RESULTATS DES NEGOCIATIONS ET A DECIDE LA SIGNATURE DE L'ACCORD, SOUS RESERVE DE CONCLUSION.</j.0:comment>
    <j.0:procedure_code_interinstitutional_reference_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1995/0132/AVC</j.0:procedure_code_interinstitutional_reference_procedure>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/11398.10856"/>
    <j.0:dossier_title xml:lang="nl">VOORSTEL VOOR EEN BESLUIT VAN DE RAAD EN DE COMMISSIE INZAKE DE SLUITING VAN DE EURO-MEDITERRANE OVEREENKOMST WAARBIJ EEN ASSOCIATIE TOT STAND WORDT GEBRACHT TUSSEN DE EUROPESE GEMEENSCHAPPEN EN HUN LID-STATEN ENERZIJDS EN DE REPUBLIEK TUNESIE ANDERZIJDS</j.0:dossier_title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/11398.13705"/>
    <j.0:procedure_code_interinstitutional_has_type_concept_type_procedure_code_interinstitutional rdf:resource="http://publications.europa.eu/resource/authority/procedure/AVC"/>
    <j.0:dossier_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/11951K095"/>
    <j.0:dossier_type_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM</j.0:dossier_type_reference>
    <j.0:dossier_adopted-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</j.0:dossier_adopted-proposal>
    <j.0:dossier_title xml:lang="es">PROPUESTA DE DECISION DEL CONSEJO Y DE LA COMISION RELATIVA A LA CELEBRACION DEL ACUERDO EUROMEDITERRANEO POR EL QUE SE ESTABLECE UNA ASOCIACION ENTRE LAS COMUNIDADES EUROPEAS Y SUS ESTADOS MIEMBROS,POR UNA PARTE,Y LA REPUBLICA DE TUNEZ,POR OTRA</j.0:dossier_title>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/comnat/COM_1995_0235_FIN"/>
    <j.0:title xml:lang="es">PROPUESTA DE DECISION DEL CONSEJO Y DE LA COMISION RELATIVA A LA CELEBRACION DEL ACUERDO EUROMEDITERRANEO POR EL QUE SE ESTABLECE UNA ASOCIACION ENTRE LAS COMUNIDADES EUROPEAS Y SUS ESTADOS MIEMBROS,POR UNA PARTE,Y LA REPUBLICA DE TUNEZ,POR OTRA</j.0:title>
    <j.0:title xml:lang="sv">FOERSLAG TILL RAADETS OCH KOMMISSIONENS BESLUT OM INGAAENDE AV EUROPA-MEDELHAVSAVTALET OM UPPRAETTANDET AV EN ASSOCIERING MELLAN EUROPEISKA GEMENSKAPERNA OCH DERAS MEDLEMSSTATER AA ENA SIDAN OCH TUNISIEN AA ANDRA SIDAN</j.0:title>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/procedure/AVC"/>
    <j.0:title xml:lang="fr">PROPOSITION DE DECISION DU CONSEIL ET DE LA COMMISSIONRELATIVE A LA CONCLUSION DE L'ACCORD EURO-MEDITERRANEEN ETABLISSANT UNE ASSOCIATION ENTRE LES COMMUNAUTES EUROPEENNES ET LEURS ETATS MEMBRES, D'UNE PART, ET LA REPUBLIQUE TUNISIENNE, D'AUTRE PART</j.0:title>
    <j.0:dossier_title xml:lang="pt">PROPOSTA DE DECISAO DO CONSELHO E DA COMISSAO RELATIVA A CONCLUSAO DO ACORDO EURO-MEDITERRANICO QUE ESTABELECE UMA ASSOCIACAO ENTRE AS COMUNIDADES EUROPEIAS E SEUS ESTADOS-MEMBROS, POR UM LADO, E A REPUBLICA DA TUNISIA, POR OUTRO</j.0:dossier_title>
    <j.0:reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1995/0132/AVC</j.0:reference>
    <j.0:dossier_title xml:lang="it">PROPOSTA DI DECISIONE DEL CONSIGLIO E DELLA COMMISSIONE RELATIVA ALLA CONCLUSIONE DELL'ACCORDO EUROMEDITERRANEO CHE ISTITUISCE UN'ASSOCIAZIONE TRA LE COMUNITA EUROPEE E I LORO STATI MEMBRI, DA UN LATO, E LA REPUBBLICA TUNISINA, DALL'ALTRO</j.0:dossier_title>
