  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/201165">
    <j.0:dossier_title xml:lang="pt">Proposta de DECISÃO DO CONSELHO relativa à posição a adoptar pela União Europeia no âmbito do Conselho de Ministros ACP-UE sobre o quadro financeiro plurianual para o período 2014 - 2020 do Acordo de Parceria ACP-UE</j.0:dossier_title>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/201165.414876"/>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/201165.423218"/>
