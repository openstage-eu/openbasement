  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/200368">
    <j.0:dossier_basis_legal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TFUE</j.0:dossier_basis_legal>
    <j.0:dossier_initiated_by_act_preparatory rdf:resource="http://publications.europa.eu/resource/celex/52011PC0207"/>
    <j.0:title xml:lang="fr">Proposition de RÈGLEMENT DU CONSEIL modifiant le règlement (CE) n° 1292/2007 instituant un droit antidumping définitif sur les importations de feuilles en polyéthylène téréphtalate (PET) originaires de l’Inde</j.0:title>
    <j.0:produces rdf:resource="http://publications.europa.eu/resource/celex/32011R0469"/>
    <j.0:title xml:lang="de">Vorschlag für eine VERORDNUNG DES RATES zur Änderung der Verordnung (EG) Nr. 1292/2007 zur Einführung eines endgültigen Antidumpingzolls auf Einfuhren von Folien aus Polyethylenterephthalat mit Ursprung in Indien</j.0:title>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#dossier"/>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/comnat/COM_2011_0207_FIN"/>
