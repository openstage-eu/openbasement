    <j.2:build_info>cdm:CDM_2.1.7  tdm:1523  xslt:3945 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:1.1.9 builddate:12/02/2014 15:59:29</j.2:build_info>
    <j.0:dossier_title xml:lang="de">Vorschlag für eine VERORDNUNG DES RATES zur Änderung der Verordnung (EG) Nr. 1292/2007 zur Einführung eines endgültigen Antidumpingzolls auf Einfuhren von Folien aus Polyethylenterephthalat mit Ursprung in Indien</j.0:dossier_title>
