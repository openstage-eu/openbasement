    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOC_2011_189_R_0006_01"/>
    <j.0:dossier_title xml:lang="pl">Wniosek ROZPORZĄDZENIE RADY zmieniające rozporządzenie (WE) nr 1292/2007 nakładające ostateczne cło antydumpingowe na przywóz folii z politereftalanu etylenu (PET) pochodzącej z Indii</j.0:dossier_title>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2011-04-14</j.0:date>
