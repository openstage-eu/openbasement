    <j.0:title xml:lang="da">Forslag til RÅDETS AFGØRELSE om den holdning, der skal indtages på Den Europæiske Unions vegne i Associeringsudvalget i dettes handelssammensætning, som er nedsat ved associeringsaftalen mellem Den Europæiske Union og Det Europæiske Atomenergifællesskab og deres medlemsstater på den ene side og Ukraine på den anden side</j.0:title>
    <j.0:dossier_number_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">468</j.0:dossier_number_reference>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/procedure-event/2021_262.2021-08-12_DIS_byCONSIL"/>
