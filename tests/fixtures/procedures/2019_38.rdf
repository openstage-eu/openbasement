  <rdf:Description rdf:about="http://publications.europa.eu/resource/procedure/2019_38">
    <j.0:dossier_type_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM</j.0:dossier_type_reference>
    <j.0:dossier_title xml:lang="mt">Proposta għal DEĊIŻJONI TAL-KUNSILL dwar il-pożizzjoni li trid tittieħed f’isem l-Unjoni Ewropea fil-Kumitati rilevanti tal-Kummissjoni Ekonomika għall-Ewropa tan-Nazzjonijiet Uniti fir-rigward tal-proposti għal modifiki tar-Regolamenti tan-NU Nri  0, 3, 4, 6, 7, 9, 10, 19, 23, 27, 38, 41, 48, 50, 51, 53, 55, 58, 62, 67, 69, 70, 73, 74, 77, 86, 87, 91, 92, 98, 104, 106, 107, 110, 112, 113, 116, 119, 122, 123 u 128, fir-rigward tal-proposta għal emenda għar-Riżoluzzjoni Konsolidata R.E.5, fir-rigward tal-proposti għal erba’ Regolamenti ġodda tan-NU, u fir-rigward tal-proposta għal emenda għall-Iskeda 4 tal-Ftehim tal-1958</j.0:dossier_title>
    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20190226-3956; environment: PROD; newCERES: 3.23.2; IMMC2CDM: 2.8.0; rules: preleg/rules-consil.xml#39852#2018-05-06; builddate: 2019-02-26T17:16:00.399;</j.2:build_info>
