  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/11448.197485">
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CS/1998/6353</j.0:event_legal_document_reference>
    <j.0:event_contains_work rdf:resource="http://publications.europa.eu/resource/celex/51998AG0527%2804%29"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/CONSIL"/>
    <j.0:event_legal_comment xml:lang="fr">Le Conseil et le Parlement européen ont exclu la proposition modifiée de la Commission sur les véhicules utilitaires légers dans les discussions déjà engagées sur les émissions des voitures particulières, et ont considéré cette proposition comme une proposition séparée modifiant la directive 70/220/CEE. La position commune adoptée par le Conseil le 23/03/1998 vise donc uniquement la proposition modifiée (COM(97)61FINAL : véhicules utilitaires légers). Elle maintient, dans la mesure du possible, le parallélisme entre les véhicules utilitaires légers et les voitures particulières afin de faciliter une probable fusion des textes au stade ultime de la procédure, éventuellement pendant la phase de conciliation</j.0:event_legal_comment>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event_legal"/>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/celex/51998AG0527%2804%29"/>
