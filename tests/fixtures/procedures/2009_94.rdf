    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/oj/JOC_2010_296_R_0011_01"/>
    <j.0:dossier_title xml:lang="cs">Návrh NAŘÍZENÍ RADY kterým se stanoví odchylka od nařízení (ES) č. 1234/2007 („jednotné nařízení o společné organizaci trhů“), pokud jde o období intervence 2009 a 2010 u másla a sušeného odstředěného mléka</j.0:dossier_title>
    <j.0:title xml:lang="it">Proposta di REGOLAMENTO DEL CONSIGLIO recante deroga al regolamento (CE) n. 1234/2007 (regolamento unico OCM) per quanto riguarda i periodi di intervento 2009 e 2010 per il burro e il latte scremato in polvere</j.0:title>
