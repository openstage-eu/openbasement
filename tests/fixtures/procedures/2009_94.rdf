    <j.2:build_info>cdm:CDM_2.1.7  tdm:1523  xslt:3945 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:1.1.9 builddate:12/02/2014 13:33:50</j.2:build_info>
    <j.0:event_legal_part_of_dossier rdf:resource="http://publications.europa.eu/resource/pegase/198426"/>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/198426"/>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:initiated_by rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:event_legal_comment xml:lang="en">The Commission is not in favour of re-establishing an aide for private storage of cheeses. These schemes have been abolished by the Council as part of the Health Check package. The support for these high value products is no longer appropriate. The schemes are not considered to be cost effective and have a very limited scope and effect.</j.0:event_legal_comment>
    <j.0:event_legal_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2009-09-17</j.0:event_legal_date>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_RSI_byCOM"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/POS_AME_RSI_byCOM"/>
    <j.0:uses rdf:resource="http://publications.europa.eu/resource/authority/fd_602/1030"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#period"/>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#event"/>
    <j.0:event_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2009-09-17</j.0:event_date>
    <j.0:comment xml:lang="en">The Commission is not in favour of re-establishing an aide for private storage of cheeses. These schemes have been abolished by the Council as part of the Health Check package. The support for these high value products is no longer appropriate. The schemes are not considered to be cost effective and have a very limited scope and effect.</j.0:comment>
    <j.0:event_legal_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position de la Commission sur les amendements du PE en lecture unique</j.0:event_legal_type>
