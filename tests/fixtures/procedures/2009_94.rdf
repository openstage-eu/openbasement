  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/198426">
    <j.0:dossier_title xml:lang="es">Propuesta de REGLAMENTO DEL CONSEJO por el que se establecen excepciones al Reglamento (CE) nº 1234/2007 (Reglamento único para las OCM) en lo relativo a los períodos de intervención de 2009 y 2010 para la mantequilla y la leche desnatada en polvo</j.0:dossier_title>
