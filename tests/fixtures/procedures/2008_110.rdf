    <j.0:title xml:lang="lv">Priekšlikums EIROPAS PARLAMENTA UN PADOMES REGULA, ar ko nosaka veselības aizsardzības noteikumus attiecībā uz dzīvnieku izcelsmes blakusproduktiem, kuri nav paredzēti cilvēku uzturam (Dzīvnieku izcelsmes blakusproduktu regula) </j.0:title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/pegase/197093.393272"/>
    <j.0:dossier_produces_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/32009R1069"/>
