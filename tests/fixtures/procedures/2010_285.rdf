    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/199752.407461"/>
    <j.0:title xml:lang="pt">Proposta de REGULAMENTO DO CONSELHO relativo à repartição das possibilidades de pesca a título do Acordo de Parceria no sector da pesca entre a Comunidade Europeia e a União das Comores</j.0:title>
    <j.0:withdrawn-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:withdrawn-proposal>
    <j.0:dossier_number_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">563</j.0:dossier_number_reference>
    <j.0:dossier_title xml:lang="hu">Javaslat: A TANÁCS RENDELETE az Európai Közösség és a Comore-szigeteki Unió közötti halászati partnerségi megállapodás szerinti halászati lehetőségek elosztásáról</j.0:dossier_title>
    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12010E043"/>
    <j.0:number_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0285</j.0:number_procedure>
    <j.0:dossier_title xml:lang="ro">Propunere de REGULAMENT AL CONSILIULUI privind alocarea posibilităților de pescuit în conformitate cu Acordul de parteneriat în sectorul pescuitului între Comunitatea Europeană și Uniunea Comorelor</j.0:dossier_title>
    <j.0:dossier_title xml:lang="mt">Proposta għal REGOLAMENT TAL-KUNSILL dwar l-allokazzjoni tal-opportunitajiet tas-sajd skont il-Ftehim ta' Sħubija dwar is-Sajd bejn il-Komunità Ewropea u l-Unjoni tal-Komoros</j.0:dossier_title>
    <j.0:dossier_title xml:lang="lt">Pasiūlymas TARYBOS REGLAMENTAS dėl žvejybos galimybių skyrimo pagal Europos bendrijos ir Komorų Sąjungos žuvininkystės sektoriaus partnerystės susitarimą</j.0:dossier_title>
    <j.0:dossier_title xml:lang="it">Proposta di REGOLAMENTO DEL CONSIGLIO relativo al metodo di ripartizione delle possibilità di pesca a norma dell'accordo di partenariato nel settore della pesca tra la Comunità europea e l'Unione delle Comore</j.0:dossier_title>
    <j.0:dossier_type_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM</j.0:dossier_type_reference>
