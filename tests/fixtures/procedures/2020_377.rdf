  <rdf:Description rdf:about="http://publications.europa.eu/resource/procedure/2020_377">
    <j.0:procedure_code_interinstitutional_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12016E168"/>
    <j.0:title xml:lang="el">Πρόταση ΣΥΣΤΑΣΗ ΤΟΥ ΣΥΜΒΟΥΛΙΟΥ σχετικά με κοινό πλαίσιο για τη χρήση, την επικύρωση και την αμοιβαία αναγνώριση ταχειών δοκιμασιών αντιγόνων για τη νόσο COVID-19 στην ΕΕ</j.0:title>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/procedure-event/2020_377.2021-01-05_DIS_byCONSIL"/>
    <j.0:title xml:lang="en">Proposal for a COUNCIL RECOMMENDATION on a common framework for the use, validation and mutual recognition of COVID-19 rapid antigen tests in the EU</j.0:title>
    <j.0:contains rdf:resource="http://publications.europa.eu/resource/immc/COM%282020%29849%20final"/>
    <j.0:withdrawn-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:withdrawn-proposal>
    <j.0:dossier_withdrawn-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:dossier_withdrawn-proposal>
    <j.0:title xml:lang="hu">Javaslat A TANÁCS AJÁNLÁSA a Covid19 antigén gyorsteszteknek az Unióban történő alkalmazása, validálása és kölcsönös elismerése közös keretéről</j.0:title>
    <j.0:dossier_identifier rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">procedure:2020_377</j.0:dossier_identifier>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/procedure-event/2020_377.2021-01-22_PUB_OJ"/>
    <j.0:title xml:lang="mt">Proposta għal RAKKOMANDAZZJONI TAL-KUNSILL dwar qafas komuni għall-użu, il-validazzjoni u r-rikonoxximent reċiproku tat-testijiet rapidi tal-antiġeni tal-COVID-19 fl-UE</j.0:title>
    <j.0:dossier_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/12016E168"/>
    <j.0:title xml:lang="nl">Voorstel voor een AANBEVELING VAN DE RAAD betreffende een gemeenschappelijk kader voor het gebruik, de validering en de wederzijdse erkenning van snelle antigeentests tegen COVID-19 in de EU</j.0:title>
