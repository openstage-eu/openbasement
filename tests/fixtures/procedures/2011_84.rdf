    <j.0:dossier_title xml:lang="sk">Návrh NARIADENIE RADY, ktorým sa ukladá konečné antidumpingové clo a s konečnou platnosťou vyberá dočasné clo uložené na dovoz melamínu s pôvodom v Čínskej ľudovej republike</j.0:dossier_title>
    <j.0:procedure_code_interinstitutional_number_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0084</j.0:procedure_code_interinstitutional_number_procedure>
