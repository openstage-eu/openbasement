    <j.0:dossier_produces_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/32011R0457"/>
    <j.0:title xml:lang="sl">Predlog UREDBA SVETA o uvedbi dokončne protidampinške dajatve in o dokončnem pobiranju začasne dajatve, uvedene na uvoz melamina s poreklom iz Ljudske republike Kitajske</j.0:title>
