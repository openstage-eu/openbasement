    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/200658.412027"/>
    <j.0:title xml:lang="pt">Proposta de DECISÃO DO CONSELHO relativa à conclusão do Acordo de cooperação científica e tecnológica entre a União Europeia, por um lado, e a República Democrática e Popular da Argélia, por outro</j.0:title>
