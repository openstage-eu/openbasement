  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/158979">
    <j.0:dossier_title xml:lang="it">Proposta di REGOLAMENTO DEL CONSIGLIO che proroga per un periodo massimo di un anno il finanziamento di taluni piani di miglioramento della qualità e della commercializzazione approvati a norma del titolo II bis del regolamento (CEE) n. 1035/72</j.0:dossier_title>
    <j.0:dossier_pending-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:dossier_pending-proposal>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/pegase/158979.307863"/>
    <j.0:dossier_title xml:lang="da">Forslag til RÅDETS FORORDNING om videreførelse i op til et år af finansieringen af visse planer for forbedring af kvalitet og fremme af afsætning, der blev godkendt i henhold til afsnit IIa i forordning (EØF) nr. 1035/72</j.0:dossier_title>
