  <rdf:Description rdf:about="http://publications.europa.eu/resource/pegase/142739.276982">
    <j.0:document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CES/1999/555</j.0:document_reference>
    <j.0:event_legal_document_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">JO C/1999/209/20</j.0:event_legal_document_reference>
    <j.0:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1999-05-26</j.0:date>
    <j.0:event_legal_comment xml:lang="fr">Le CES a rendu un avis favorable à cette proposition, notamment du fait de son caractère volontariste et expérimental, le Comité souhaiterait de plus être associé à l'évaluation des rapports que les États membres autorisés à appliquer le taux de TVA réduit devront présenter.</j.0:event_legal_comment>
    <j.0:part_of rdf:resource="http://publications.europa.eu/resource/pegase/142739"/>
