    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/procedure-event/2023_372.2023-11-07_DIS_byCONSIL"/>
    <j.0:dossier_type_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM</j.0:dossier_type_reference>
    <j.0:title xml:lang="cs">Návrh ROZHODNUTÍ RADY o postoji, který má být zaujat jménem Evropské unie v rámci Světového fóra Evropské hospodářské komise Organizace spojených národů pro harmonizaci předpisů týkajících se vozidel k návrhům změn předpisů OSN č. 0, 14, 16, 17, 24, 43, 48, 53, 74, 86, 90, 94, 95, 100, 122, 129, 134, 135, 137, 145, 149, 153, 154, 157, 160, 161 a 162, k návrhu nového předpisu OSN o zapisovačích údajů o události pro těžká nákladní vozidla a návrhu nového předpisu OSN o dětských zádržných systémech pro bezpečnější přepravu dětí v autobusech a k návrhu změny vzájemného usnesení OSN č. 1</j.0:title>
    <j.0:identifier rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">procedure:2023_372</j.0:identifier>
