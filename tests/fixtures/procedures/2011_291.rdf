    <j.0:number_procedure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0291</j.0:number_procedure>
    <j.0:title xml:lang="bg">Предложение за РЕШЕНИЕ НА СЪВЕТА относно позицията, която ще бъде взета от името на Европейския съюз в съвместния комитет, създаден съгласно Споразумението между Европейската общност и нейните държави-членки, от една страна, и Конфедерация Швейцария, от друга, относно свободното движение на хора във връзка със замяната на приложение ІІ към Споразумението относно координация на схемите за социална сигурност</j.0:title>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/200955.415351"/>
