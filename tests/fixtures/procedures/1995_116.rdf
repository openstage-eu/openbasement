    <j.2:build_info>cdm:3840  tdm:1523  xslt:3886 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:3886 builddate:19/07/2012 17:28:34</j.2:build_info>
    <j.0:event_initiated_by_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/COM"/>
    <j.0:associated_with rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/DG03"/>
    <j.0:formally-addresses rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/CONSIL"/>
    <j.0:event_legal_comment xml:lang="fr">L'arrêt rendu par la Cour de Justice (C-106/98) sur la base juridique des lignes budgétaires a entraîné la suspension de l'utilisation de crédits subsistants pour le Japon en 1998. La proposition de 1995 doit être modifiée tant en ce qui concerne la substance que la base juridique même. Le Conseil est invité à entériner rapidement la proposition modifiée afin d'éviter la disparition progressive des programmes existants et de l'infrastructure qui y est associée</j.0:event_legal_comment>
    <j.0:event_contains_work rdf:resource="http://publications.europa.eu/resource/celex/51998PC0722"/>
    <j.0:responsibility_of rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/DG01"/>
    <j.0:mandatorily-consults rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/EP"/>
    <j.0:event_legal_responsibility_of_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/DG01"/>
    <j.0:based_on rdf:resource="http://publications.europa.eu/resource/celex/11992E113"/>
    <j.0:event_has_type_concept_type_event rdf:resource="http://publications.europa.eu/resource/authority/event/ADP_PROPAME_byCOM"/>
    <j.0:event_legal_formally-addresses_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/CONSIL"/>
    <j.0:event_associated_with_institution rdf:resource="http://publications.europa.eu/resource/authority/corporate-body/DG15"/>
    <j.0:comment xml:lang="fr">L'arrêt rendu par la Cour de Justice (C-106/98) sur la base juridique des lignes budgétaires a entraîné la suspension de l'utilisation de crédits subsistants pour le Japon en 1998. La proposition de 1995 doit être modifiée tant en ce qui concerne la substance que la base juridique même. Le Conseil est invité à entériner rapidement la proposition modifiée afin d'éviter la disparition progressive des programmes existants et de l'infrastructure qui y est associée</j.0:comment>
    <j.0:event_based_on_resource_legal rdf:resource="http://publications.europa.eu/resource/celex/11992E189A"/>
    <j.0:has_remark rdf:resource="http://publications.europa.eu/resource/authority/fd_603/1080"/>
