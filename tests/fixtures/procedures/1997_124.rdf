    <j.2:build_info>cdm:3840  tdm:1523  xslt:3886 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:3886 builddate:19/07/2012 18:27:52</j.2:build_info>
    <j.0:event_legal_has_type_concept_type_event_legal rdf:resource="http://publications.europa.eu/resource/authority/event/TRS_EP_DCLCOMPOS_byCOM"/>
    <j.0:has_type rdf:resource="http://publications.europa.eu/resource/authority/event/TRS_EP_DCLCOMPOS_byCOM"/>
    <j.0:event_legal_comment xml:lang="fr">La Commission juge acceptable en tous points la position commune du Conseil. Celle-ci intègre tous les amendements du Parlement européen et complète la proposition initiale et la proposition modifiée de la Commission par des précisions utiles et des dispositions nouvelles qui traduisent l'évolution intervenue dans l'environnement réglementaire international depuis l'adoption de la proposition initiale de la Commission</j.0:event_legal_comment>
