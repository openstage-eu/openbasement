    <j.0:title xml:lang="fr">Proposition de DÉCISION DU CONSEIL relative à la position à prendre au nom de l'Union européenne au sein du Comité APE institué par l'accord de partenariat économique d'étape entre la Côte d'Ivoire, d'une part, et la Communauté européenne et ses États membres, d'autre part concernant l'adhésion de la République de Croatie à l'Union européenne</j.0:title>
    <rdf:type rdf:resource="http://publications.europa.eu/ontology/cdm#entity_temporal"/>
    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20180827-796; environment: PROD; newCERES: 3.23.0; IMMC2CDM: 2.8.0; rules: preleg/rules-consil.xml#39852#2018-05-06; builddate: 2018-08-27T09:23:28.147;</j.2:build_info>
