    <j.0:dossier_title xml:lang="fi">Ehdotus NEUVOSTON TÄYTÄNTÖÖNPANOPÄÄTÖS päätöksen 2009/791/EU muuttamisesta luvan antamiseksi Saksalle jatkaa yhteisestä arvonlisäjärjestelmästä annetun direktiivin 2006/112/EY 168 artiklasta poikkeavan toimenpiteen soveltamista</j.0:dossier_title>
    <j.0:type_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM</j.0:type_reference>
    <j.0:dossier_title xml:lang="lv">Priekšlikums PADOMES ĪSTENOŠANAS LĒMUMS, ar kuru groza Lēmumu 2009/791/EK, ar ko Vācijai atļauj arī turpmāk piemērot pasākumu, ar kuru atkāpjas no 168. panta Direktīvā 2006/112/EK par kopējo pievienotās vērtības nodokļa sistēmu</j.0:dossier_title>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/procedure-event/2021_249.2021-07-30_DIS_byCONSIL"/>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/celex/32021D1776"/>
