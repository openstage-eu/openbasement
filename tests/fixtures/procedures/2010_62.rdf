    <j.0:dossier_year_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2010</j.0:dossier_year_reference>
    <j.0:title xml:lang="fr">Proposition de DÉCISION DU CONSEIL relative à la conclusion d’un accord de partenariat volontaire entre l'Union européenne et la République du Congo sur l’application des réglementations forestières, la gouvernance et les échanges commerciaux des bois et produits dérivés vers l'Union européenne (FLEGT)</j.0:title>
    <j.0:dossier_pending-proposal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</j.0:dossier_pending-proposal>
    <j.0:dossier_date_adopted rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2011-02-28</j.0:dossier_date_adopted>
    <j.0:reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2010/0062/NLE</j.0:reference>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/199164.409682"/>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/199164.409054"/>
    <j.0:dossier_title xml:lang="es">Propuesta de DECISIÓN DEL CONSEJO referente a la celebración de un Acuerdo de Asociación Voluntaria entre la Unión Europea y la República del Congo relativo a la aplicación de las leyes, la gobernanza y el comercio de la madera y los productos derivados importados en la Unión Europea (FLEGT)</j.0:dossier_title>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/199164.404533"/>
    <j.0:title xml:lang="fi">Ehdotus NEUVOSTON PÄÄTÖS metsälainsäädännön soveltamisen valvontaa, metsähallintoa ja puutuotteiden kauppaa Euroopan unioniin koskevan Euroopan unionin ja Kongon tasavallan vapaaehtoisen kumppanuussopimuksen (FLEGT) tekemisestä</j.0:title>
    <j.0:dossier_contains_event_legal rdf:resource="http://publications.europa.eu/resource/pegase/199164.404534"/>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/comnat/COM_2010_0118_FIN"/>
    <j.0:title xml:lang="pl">Wniosek DECYZJA RADY w sprawie zawarcia dobrowolnej umowy o partnerstwie pomiędzy Unią Europejską i Republiką Konga dotyczącej egzekwowania prawa, zarządzania i handlu w dziedzinie leśnictwa oraz handlu produktami z drewna wprowadzanymi na terytorium Unii Europejskiej</j.0:title>
    <j.0:number_reference rdf:datatype="http://www.w3.org/2001/XMLSchema#string">118</j.0:number_reference>
    <j.0:dossier_contains_work rdf:resource="http://publications.europa.eu/resource/celex/32011D0202"/>
