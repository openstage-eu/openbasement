    <j.0:dossier_title xml:lang="cs">Návrh ROZHODNUTÍ RADY o postoji, který má být zaujat jménem Evropské unie v regionálním řídícím výboru Dopravního společenství, pokud jde o některé rozpočtové a personální záležitosti ve vztahu k provádění Smlouvy o založení Dopravního společenství</j.0:dossier_title>
    <j.0:dossier_contains_event rdf:resource="http://publications.europa.eu/resource/procedure-event/2018_408.2019-01-16_DIS_byCONSIL"/>
